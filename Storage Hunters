            -- Dynamic Pawn Sell check
            local targetMultiplier = 1 + (State.MinPawnPercent / 100)
            if State.DynamicPawnSell and currentPawnRate < targetMultiplier then
                local currentPct = math.round((currentPawnRate - 1) * 100)
                State.status = string.format("⏳ Pawn rate %+d%% < Min %+d%%", currentPct, State.MinPawnPercent)
