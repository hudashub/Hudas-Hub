            if g and g.Name ~= "" then
                pcall(addDropdownItem, "Auctions", g.Name)
            end
        end
        track(garages.ChildAdded:Connect(onChild))
        for _, g in ipairs(garages:GetChildren()) do
            task.spawn(onChild, g)
        end
    end
end
pcall(listenToNewGarages)

