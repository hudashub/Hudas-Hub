        makeNote(spBody, "How it works: run with Auto-Battle Farm targeting ONE species. Normals are caught with the build ball to raise prismatic pity; at max-1 it PARKS — normals are only defeated (shiny pity keeps building) and the guaranteed prismatic stays reserved. Any shiny gets the catch ball, and on a parked pity that catch is a shiny + prismatic. Pity is per-species.", 5)

        local ballBody = makeCard(colB, "⚾", "Ball Selection", 1)
