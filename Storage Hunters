local activeDropdowns = {}
local function addDropdownItem(titleText, item)
    local dd = activeDropdowns[titleText]
    if not dd then return end
    for _, it in ipairs(dd.items) do
        if it == item then return end
    end
    table.insert(dd.items, item)
    table.sort(dd.items)
    for _, ch in ipairs(dd.content:GetChildren()) do
        if ch:IsA("Frame") and ch.LayoutOrder > 0 then
            ch:Destroy()
        end
    end
    table.clear(dd.refreshers)
    for i, it in ipairs(dd.items) do
        local row = Instance.new("Frame", dd.content)
        row.Size = UDim2.new(1, 0, 0, dd.rowH); row.BackgroundColor3 = Color3.fromRGB(8, 8, 9); row.BorderSizePixel = 0; row.LayoutOrder = i
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)
        local cb = Instance.new("Frame", row)
        cb.Size = UDim2.fromOffset(16, 16); cb.Position = UDim2.new(0, 8, 0.5, -8); cb.BorderSizePixel = 0
        Instance.new("UICorner", cb).CornerRadius = UDim.new(0, 4)
        local ck = mkLabel(cb, "", UDim2.fromScale(1, 1), UDim2.new(0, 0, 0, -1), 12, Enum.Font.GothamBold, Color3.new(1, 1, 1), 2, Enum.TextXAlignment.Center)
        mkLabel(row, it, UDim2.new(1, -34, 1, 0), UDim2.new(0, 32, 0, 0), 11, nil, Color3.fromRGB(180, 180, 180), 1)
        local rb = Instance.new("TextButton", row); rb.Size = UDim2.fromScale(1, 1); rb.BackgroundTransparency = 1; rb.Text = ""
        local function rf()
            local on = dd.getState(it)
            cb.BackgroundColor3 = on and Color3.fromRGB(235, 70, 50) or Color3.fromRGB(18, 18, 20)
            ck.Text = on and "X" or ""
        end
        rb.MouseButton1Click:Connect(function() dd.setState(it, not dd.getState(it)); rf(); dd.updateBadge() end)
        table.insert(dd.refreshers, rf)
        rf()
    end
    local holder = dd.content.Parent
    local open = (holder.Size.Y.Offset > 40)
    local newContentH = 30 * #dd.items + 34
    if open then
        holder.Size = UDim2.new(1, 0, 0, 40 + newContentH)
    end
    dd.content.Size = UDim2.new(1, 0, 0, newContentH)
    dd.updateBadge()
end

