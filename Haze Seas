        scroller.CanvasSize = UDim2.new(0, 0, 0, h1 + 30)
    end
    track(l1:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas))
    task.spawn(updateCanvas)

    return col1, col2
end

