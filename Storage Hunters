            if not score then
                local rarity = tostring(info.Rarity or ""):lower()
                score = RARITY_TIERS[rarity] or 1
            end
            if score > bestScore then
                bestScore = score
                bestGuid = guid
            end
        end
    end
    
    cachedBestVehicleGuid = bestGuid
    return bestGuid
