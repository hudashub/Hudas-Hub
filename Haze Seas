-- ── RenderStepped: instant zero-delay mob attachment every frame ────
-- Runs client-side before each render. Sets CFrame directly so the
-- character moves WITH the mob instantly, no spring/delay.
track(RunService.RenderStepped:Connect(function()
    if not State.AutoFarmLevel then return end
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not currentTargetMob then return end
    local mobHum = currentTargetMob:FindFirstChild("Humanoid")
    if not mobHum or mobHum.Health <= 0 then return end
    local mobRoot = currentTargetMob:FindFirstChild("HumanoidRootPart")
    if not mobRoot then return end

    local targetPos = mobRoot.Position
    local wantedPos
    if State.FarmPosition == "Above" then
        wantedPos = targetPos + Vector3.new(0, State.FarmDistance, 0)
    elseif State.FarmPosition == "Under" then
        wantedPos = targetPos + Vector3.new(0, -State.FarmDistance, 0)
    else -- Behind: offset in the mob's own local Z axis
        wantedPos = (mobRoot.CFrame * CFrame.new(0, 0, State.FarmDistance)).Position
    end

    -- Direct lock to position so there is zero latency/lag relative to the mob,
    -- which completely eliminates camera bounce/shake when the mob moves.
    local targetCF = CFrame.new(wantedPos, targetPos)
    root.CFrame = targetCF
    pcall(function()
        root.AssemblyLinearVelocity = Vector3.new(0,0,0)
        root.AssemblyAngularVelocity = Vector3.new(0,0,0)
    end)
end))



