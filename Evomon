        makeNote(gcBody, "Known codes: " .. table.concat(GIFT_CODES, ", "), 3)

        local clBody = makeCard(colB, "📬", "Claims", 1)
        makeButton(clBody, "Claim Daily + Online", "ghost", 1, function(b) busy(b, function() claimDaily(); claimOnline() end) end)
        makeButton(clBody, "Claim All Mail", "ghost", 2, function(b) busy(b, function() claimMail() end) end)
        makeNote(clBody, "Best-effort claims — anything already claimed is simply skipped by the server.", 3)
    end

    -- ===================== PAGE: SETTINGS =====================
    do
        local colA, colB = makeRow(PAGES.settings, 1)
        local profBody = makeCard(colA, "💾", "Profiles", 1)
        local hasFiles = (writefile and readfile and listfiles and isfolder and makefolder and delfile) and true or false
        local function ensureFolder() if hasFiles and not isfolder(HUB.profDir) then pcall(makefolder, HUB.profDir) end end
        local function ppath(n) return HUB.profDir .. "/" .. n .. ".json" end
        local function listProfiles()
            local out = {}
            if not hasFiles or not isfolder(HUB.profDir) then return out end
            local ok, files = pcall(listfiles, HUB.profDir)
            if ok then
                for _, f in ipairs(files) do
                    local nm = f:match("([^/\\]+)%.json$")
                    if nm then table.insert(out, nm) end
                end
            end
            return out
        end
        local function saveProfile(n)
            if not hasFiles or n == "" then return false end
            ensureFolder()
            local data = {}
            for k, c in pairs(controls) do
                local ok, v = pcall(c.get)
                if ok then data[k] = v end
            end
            return (pcall(function() writefile(ppath(n), HttpService:JSONEncode(data)) end))
        end
        local function applyProfile(n)
            if not hasFiles then return false end
            local ok, raw = pcall(readfile, ppath(n)); if not ok then return false end
            local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
            if not ok2 or type(data) ~= "table" then return false end
            for k, v in pairs(data) do if controls[k] then pcall(controls[k].set, v) end end
            return true
        end
        if not hasFiles then
            makeNote(profBody, "This executor has no file API — profiles are unavailable.", 1)
        else
            local irow = Instance.new("Frame")
            irow.Size = UDim2.new(1, 0, 0, 34); irow.BackgroundTransparency = 1
            irow.LayoutOrder = 1; irow.Parent = profBody
            local nameBox = makeInput(irow, "new profile name…")
            nameBox.Size = UDim2.new(1, -86, 1, 0)
            local createBtn = Instance.new("TextButton")
            createBtn.Size = UDim2.new(0, 80, 1, 0); createBtn.Position = UDim2.new(1, -80, 0, 0)
            createBtn.BackgroundColor3 = COL.red; createBtn.AutoButtonColor = false
            createBtn.Font = Enum.Font.GothamBold; createBtn.Text = "Create"
            createBtn.TextColor3 = COL.white; createBtn.TextSize = 12; createBtn.Parent = irow
            corner(createBtn, 8)
            onHover(createBtn, { BackgroundColor3 = COL.redHi }, { BackgroundColor3 = COL.red })

            local selected = nil
            local actionRow
            local setProf
            setProf = makeDropdown(profBody, 2, {
                label = "Saved profiles",
                options = function()
                    local t = {}
                    for _, nm in ipairs(listProfiles()) do t[#t + 1] = { text = nm, value = nm } end
                    if #t == 0 then t[1] = { text = "(no profiles yet)", value = nil } end
                    return t
                end,
                current = function() return selected or "Select profile…" end,
                onPick = function(v)
                    if v then
                        selected = v
                        setProf(v)
                        actionRow.Visible = true
                    end
                end,
                allowNil = false,
            })
            setProf("Select profile…", true)

            actionRow = Instance.new("Frame")
            actionRow.Size = UDim2.new(1, 0, 0, 32); actionRow.BackgroundTransparency = 1
            actionRow.Visible = false; actionRow.LayoutOrder = 3; actionRow.Parent = profBody
            hlist(actionRow, 6)
            local function mkAction(txt, style, ord, cb)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1 / 3, -4, 1, 0); b.AutoButtonColor = false
                b.Font = Enum.Font.GothamBold; b.Text = txt; b.TextSize = 11
                b.LayoutOrder = ord; b.Parent = actionRow
                corner(b, 8)
                if style == "primary" then
                    b.BackgroundColor3 = COL.red; b.TextColor3 = COL.white
                    onHover(b, { BackgroundColor3 = COL.redHi }, { BackgroundColor3 = COL.red })
                elseif style == "danger" then
                    b.BackgroundColor3 = COL.danger; b.TextColor3 = Color3.fromRGB(255, 158, 152)
                    onHover(b, { BackgroundColor3 = Color3.fromRGB(90, 33, 36) }, { BackgroundColor3 = COL.danger })
                else
                    b.BackgroundColor3 = COL.field; b.TextColor3 = COL.text
                    softStroke(b, 0.92)
                    onHover(b, { BackgroundColor3 = COL.fieldHi }, { BackgroundColor3 = COL.field })
                end
                b.MouseButton1Click:Connect(function() pcall(cb) end)
            end
            mkAction("Load", "primary", 1, function() if selected then applyProfile(selected) end end)
            mkAction("Overwrite", "ghost", 2, function() if selected then saveProfile(selected) end end)
            mkAction("Delete", "danger", 3, function()
                if selected then
                    pcall(delfile, ppath(selected))
                    selected = nil
                    setProf("Select profile…", true)
                    actionRow.Visible = false
                end
            end)
            createBtn.MouseButton1Click:Connect(function()
                local nm = (nameBox.Text or ""):gsub("^%s+", ""):gsub("%s+$", "")
                if nm == "" then return end
                if saveProfile(nm) then
                    nameBox.Text = ""
                    selected = nm
                    setProf(nm)
                    actionRow.Visible = true
                end
            end)
        end

        local genBody = makeCard(colB, "⚙", "General", 1)
        makeToggle(genBody, "Anti-AFK", "antiAfk", 1, "Blocks the 20-minute idle kick")
        makeNote(genBody, "The window stays on top of the game UI. Drag the sidebar header or the page title to move it. Click the floating EV button to hide or show the hub.", 2)
    end

    -- dashboard updater (replaces the old terminal stats box)
    local startedAt = os.time()
    task.spawn(function()
        while alive() do
            pcall(function()
                local list = gather(TYPE_WILD, activeMaxDist(), speciesFilter)
                local near = list[1]
                statBattle.Text = inBattle and "In Battle" or "Free"
                statBattle.TextColor3 = inBattle and COL.red or COL.text
                if near then
                    statTarget.Text = string.format("%s · %dm", near.name, math.floor(near.dist))
                elseif speciesFilter ~= "" then
                    statTarget.Text = speciesFilter .. " (none)"
                else
                    statTarget.Text = "None in range"
                end
                statWalk.Text = navStatus
                statWild.Text = string.format("%d  ·  range %d", #list, activeMaxDist())
                statSmart.Text = F.smartBattle and "Active" or "Off"
                statSmart.TextColor3 = F.smartBattle and COL.red or COL.text
                local el = os.time() - startedAt
                statRuntime.Text = string.format("%02d:%02d:%02d",
                    math.floor(el / 3600), math.floor(el % 3600 / 60), el % 60)
                -- Ball Selection gating status (dropdowns only apply under Auto Catch)
                if ballStateLbl then
                    if F.spFarm then
                        ballStateLbl.Text = "● Overridden — Shiny+Prismatic Farm is ON and uses its own balls; these do nothing while it runs."
                        ballStateLbl.TextColor3 = COL.red
                    elseif F.autoCatch then
                        ballStateLbl.Text = "● Active — thrown at the catch screen per category."
                        ballStateLbl.TextColor3 = COL.text
                    else
                        ballStateLbl.Text = "○ Auto Catch is OFF — these balls are not used until you turn it on."
                        ballStateLbl.TextColor3 = COL.sub
                    end
                end
                -- live per-species pity for the current farm target
                if spPityLbl then
                    if near and near.cfgId then
                        local sc, sm, pc, pm = pityInfo(near.cfgId)
                        if type(pm) == "number" and pm > 0 then
                            local parked = (pc + 1 >= pm)
                            spPityLbl.Text = string.format("%s pity — Shiny %s/%s  ·  Prismatic %s/%s%s",
                                near.name, tostring(sc or "?"), tostring(sm or "?"),
                                tostring(pc), tostring(pm),
                                parked and "   ● PARKED — next catch = prismatic" or "")
                            spPityLbl.TextColor3 = parked and COL.red or COL.text
                        else
                            spPityLbl.Text = near.name .. " — no shiny/prismatic pity (evolved or no shiny variant); target a base species"
                            spPityLbl.TextColor3 = COL.sub
                        end
                    else
                        spPityLbl.Text = "Pity: no wild in range"
                        spPityLbl.TextColor3 = COL.sub
                    end
                end
            end)
            task.wait(0.5)
        end
    end)

    -- floating circular logo button --------------------------------------------
    local function resolveLogo()
        if HUB.logoAsset ~= "" then return HUB.logoAsset end
        local ok, id = pcall(function()
            if getcustomasset and isfile and isfile(HUB.logoFile) then return getcustomasset(HUB.logoFile) end
        end)
        if ok and type(id) == "string" then return id end
        return nil
    end
    fab = Instance.new("TextButton")
    fab.Name = "Toggle"; fab.Size = UDim2.fromOffset(52, 52); fab.Position = UDim2.fromScale(0.03, 0.42)
    fab.BackgroundColor3 = COL.bg; fab.AutoButtonColor = false; fab.Text = ""
    fab.Active = true; fab.ZIndex = 20; fab.Parent = screen
    corner(fab, 26)
    do local ring = Instance.new("UIStroke", fab); ring.Color = COL.red; ring.Thickness = 2; ring.Transparency = 0.1 end
    do
        local logoId = resolveLogo()
        if logoId then
            local logo = Instance.new("ImageLabel")
            logo.Size = UDim2.fromScale(0.84, 0.84); logo.Position = UDim2.fromScale(0.08, 0.08)
            logo.BackgroundTransparency = 1; logo.Image = logoId; logo.ZIndex = 21; logo.Parent = fab
            corner(logo, 24)
        else
            local t = Instance.new("TextLabel")
            t.Size = UDim2.fromScale(1, 1); t.BackgroundTransparency = 1; t.Font = Enum.Font.GothamBlack
            t.Text = "EV"; t.TextColor3 = COL.red; t.TextSize = 17; t.ZIndex = 21; t.Parent = fab
        end
    end
    do
        local dragging, moved, startInput, startPos
        fab.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true; moved = false; startInput = i.Position; startPos = fab.Position
            end
        end)
        track(UserInputService.InputChanged:Connect(function(i)
            if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                local d = i.Position - startInput
                if math.abs(d.X) + math.abs(d.Y) > 6 then moved = true end
                fab.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
            end
        end))
        track(UserInputService.InputEnded:Connect(function(i)
            if dragging and (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then
                dragging = false
                if not moved then main.Visible = not main.Visible end
                applyResponsive()
            end
        end))
    end

    if camera then track(camera:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsive)) end
    task.defer(applyResponsive)
    applyResponsive()
    selectPage("dash")
end
