local function fmt(n)
    n = math.floor(tonumber(n) or 0)
    if n >= 1e12 then return string.format("%.2fT", n/1e12)
    elseif n >= 1e9 then return string.format("%.2fB", n/1e9)
    elseif n >= 1e6 then return string.format("%.2fM", n/1e6)
    elseif n >= 1e3 then return string.format("%.2fK", n/1e3)
    else return tostring(n) end
end
local function statsText()
    return string.format(
        "Cash: $%s   Tier: %s\nChickens: %s   Eggs: %s\nProcess Lvl: %s   Selling: %s\nPending: $%s   Egg Mult: %.2fx",
        fmt(S("Cash")), tostring(S("BuyTierLevel") or 1),
        fmt(S("TotalChickens")), fmt(S("Eggs")),
        tostring(S("ProcessingLevel") or 1), fmt(S("EggsProcessing")),
        fmt(S("CashCollect")), eggMult())
end

