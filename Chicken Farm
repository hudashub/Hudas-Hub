        pcall(function()
            if F.mergeChickens then doMergeChickens() end
            if F.upgradeTier   then doUpgradeTier()   end
            if F.upgradeProc   then doUpgradeProc()   end
            if F.buyChickens   then doBuyChickens()   end
            if F.autoLucky     then doLuckyBlocks()   end
        end)
        task.wait(0.6)
    end
end)

