local cachedBestVehicleGuid = nil
local function getBestOwnedVehicleGuid()
    if cachedBestVehicleGuid then
        return cachedBestVehicleGuid
    end
    
    local ok, owned = pcall(function() return R.GetOwnedVehicles:InvokeServer() end)
    if not ok or not owned or type(owned.vehicles) ~= "table" then
        return "STARTER-DUSTER"
    end
    
    local bestGuid = "STARTER-DUSTER"
    local bestScore = -1
    
    for guid, info in pairs(owned.vehicles) do
        local name = info.Name
        if name then
