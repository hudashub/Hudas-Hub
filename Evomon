                end
                if not cwOpen then inBattle = false end
            end
        end
        task.wait(1)
    end
end)

-- ============================================================
--  AUTO-RELEASE  (free unwanted evomon by talent + mutation filters)
--  Releases via PetService.reqRemovePets({uuid}) — the game's own
--  canRemovePets validates first, so team / locked / loved pets are never
--  freed even if they slip through our own checks. Released one at a time so a
--  single protected pet can't reject the whole batch.
-- ============================================================
local PetService, PetComm
pcall(function() PetService = require(ReplicatedStorage.Script.Pet.PetService) end)
pcall(function() PetComm = require(ReplicatedStorage.Script.Pet.PetComm) end)
local function petIsShiny(p)
    if PetComm and typeof(PetComm.isShinyPet) == "function" then
        local ok, r = pcall(PetComm.isShinyPet, p.configId); if ok then return r == true end
    end
    return false
end
local function petIsPrismatic(p)
    if p.colorful ~= nil then return true end
    if PetComm and typeof(PetComm.isPetColorful) == "function" then
        local ok, r = pcall(PetComm.isPetColorful, p); if ok then return r == true end
    end
    return false
end
-- keep (do NOT release) if protected, a kept mutation, or talent at/above threshold
local function shouldRelease(p)
    if p.locked or p.loved then return false end
    if F.keepShiny and petIsShiny(p) then return false end
    if F.keepPrismatic and petIsPrismatic(p) then return false end
    local rank = TALENT_RANK[p.talentId] or 0
    if rank >= keepTalentRank() then return false end
    return true
end
local function collectReleasable()
    local out = {}
    if not PetService then return out end
    local ec, data = PetService.getPlayerPetData()
    if ec ~= 20000 or type(data) ~= "table" or type(data.petList) ~= "table" then return out end
    for uuid, p in pairs(data.petList) do
        if type(p) == "table" and shouldRelease(p) then out[#out + 1] = tostring(uuid) end
    end
    return out
end
local releaseStatus = "idle"
task.spawn(function()
    while alive() do
        if F.autoRelease and PetService then
            local list = collectReleasable()
            if #list > 0 then
                releaseStatus = "releasing " .. #list
                for _, uuid in ipairs(list) do
                    if not (F.autoRelease and alive()) then break end
                    pcall(function() PetService.reqRemovePets({ uuid }) end)
                    task.wait(0.35)
                end
            else
                releaseStatus = "none to release"
            end
        else
            releaseStatus = "off"
        end
        task.wait(5)
    end
end)

