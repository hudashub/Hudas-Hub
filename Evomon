    do
        local colA, colB = makeRow(PAGES.rewards, 1)
        local gcBody = makeCard(colA, "🎁", "Gift Codes", 1)
        makeButton(gcBody, "Redeem Known Codes", "primary", 1, function(b) busy(b, function() redeemCodes("") end) end)
        local crow = Instance.new("Frame")
        crow.Size = UDim2.new(1, 0, 0, 34); crow.BackgroundTransparency = 1
        crow.LayoutOrder = 2; crow.Parent = gcBody
        local codeBox = makeInput(crow, "custom gift code…")
        codeBox.Size = UDim2.new(1, -86, 1, 0)
        local cgo = Instance.new("TextButton")
