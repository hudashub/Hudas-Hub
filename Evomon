--  live dashboard tiles instead of the old terminal stats box.
--  Functionality is untouched — same flags, same controls keys,
--  so old profiles still load.
--  Wrapped in one function to stay clear of Luau's 200-local
--  per-function cap (see the SH hub incident).
-- ============================================================
local function __EV_ui()
    local TweenService = game:GetService("TweenService")

    local COL = {
        bg       = Color3.fromRGB(18, 18, 18),    -- matte black window
        side     = Color3.fromRGB(14, 14, 15),    -- sidebar, one step darker
        panel    = Color3.fromRGB(28, 28, 31),    -- #1C1C1F cards
        field    = Color3.fromRGB(23, 23, 26),    -- inputs / dropdowns / segment tracks
        fieldHi  = Color3.fromRGB(40, 40, 45),    -- hover
        red      = Color3.fromRGB(229, 57, 53),   -- #E53935 crimson
        redHi    = Color3.fromRGB(240, 82, 77),
        danger   = Color3.fromRGB(70, 26, 28),
        text     = Color3.fromRGB(242, 242, 246),
        sub      = Color3.fromRGB(148, 148, 158),
        trackOff = Color3.fromRGB(45, 45, 51),
        white    = Color3.fromRGB(255, 255, 255),
        sep      = Color3.fromRGB(255, 255, 255), -- used at ~93% transparency
    }

    -- tiny builders --------------------------------------------------------
    local function tween(o, t, props)
        pcall(function()
            TweenService:Create(o, TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
        end)
    end
    local function corner(o, r) local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 10); c.Parent = o end
    local function pad(o, t, b, l, r)
        local p = Instance.new("UIPadding", o)
        p.PaddingTop = UDim.new(0, t); p.PaddingBottom = UDim.new(0, b or t)
        p.PaddingLeft = UDim.new(0, l or t); p.PaddingRight = UDim.new(0, r or l or t)
    end
    local function vlist(o, gap)
        local l = Instance.new("UIListLayout", o)
        l.Padding = UDim.new(0, gap or 10); l.SortOrder = Enum.SortOrder.LayoutOrder
        return l
    end
    local function hlist(o, gap)
        local l = vlist(o, gap); l.FillDirection = Enum.FillDirection.Horizontal
        return l
    end
    local function softStroke(o, tr)
        local s = Instance.new("UIStroke", o)
        s.Color = COL.sep; s.Transparency = tr or 0.93; s.Thickness = 1
        return s
    end
    local function separator(parent, order)
        local f = Instance.new("Frame")
        f.Size = UDim2.new(1, 0, 0, 1); f.BackgroundColor3 = COL.sep; f.BackgroundTransparency = 0.93
        f.BorderSizePixel = 0; f.LayoutOrder = order or 0; f.Parent = parent
        return f
    end
    local function onHover(o, enterProps, leaveProps)
        o.MouseEnter:Connect(function() tween(o, 0.15, enterProps) end)
        o.MouseLeave:Connect(function() tween(o, 0.15, leaveProps) end)
    end

    -- window ---------------------------------------------------------------
    local guiParent
    pcall(function()
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 5)
        if pg then guiParent = pg end
    end)
    if not guiParent then
        pcall(function()
            if gethui then
                local h = gethui()
                if h and h:IsA("ScreenGui") then h = h.Parent end
                if h then guiParent = h end
            end
        end)
    end
    if not guiParent then guiParent = game:GetService("CoreGui") end
    pcall(function()
        local prev = guiParent:FindFirstChild(HUB.guiName)
        if prev then prev:Destroy() end
    end)
    local screen = Instance.new("ScreenGui")
    screen.Name = HUB.guiName
    screen.ResetOnSpawn = false
    screen.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    screen.DisplayOrder = 999999999          -- always on top of every other gui
    pcall(function() screen.OnTopOfCoreBlur = true end)
    screen.Parent = guiParent

    local DESIGN_W, DESIGN_H = 760, 500
    local SIDEBAR_W = 156
    local main = Instance.new("Frame")
    main.Size = UDim2.fromOffset(DESIGN_W, DESIGN_H)
    main.Position = UDim2.fromScale(0.5, 0.08)
    main.AnchorPoint = Vector2.new(0.35, 0)
    main.BackgroundColor3 = COL.bg
    main.BorderSizePixel = 0
    main.Active = true
    main.ClipsDescendants = true
    main.Parent = screen
    corner(main, 14)
    softStroke(main, 0.88)

    -- responsive scaling ----------------------------------------------------
    local camera = workspace.CurrentCamera
    local fab
    local uiScale = Instance.new("UIScale"); uiScale.Parent = main
    local function responsiveHeight()
        local vp = camera and camera.ViewportSize
        if not vp or vp.Y < 1 then return DESIGN_H end
        local s = uiScale.Scale > 0 and uiScale.Scale or 1
        return math.min(DESIGN_H, (vp.Y * 0.92) / s)
    end
    local function applyResponsive()
        local vp = camera and camera.ViewportSize
        if not vp or vp.X < 1 or vp.Y < 1 then return end
        local scale = math.clamp(math.min(vp.X / 1500, vp.Y / 820), 0.5, 1.15)
        uiScale.Scale = scale
        main.Size = UDim2.fromOffset(DESIGN_W, responsiveHeight())
        local pxW, pxH = DESIGN_W * scale, responsiveHeight() * scale
        if main.AbsoluteSize.X > 0 then
            local ap = main.AbsolutePosition
            main.AnchorPoint = Vector2.new(0, 0)
            main.Position = UDim2.fromOffset(
                math.clamp(ap.X, 0, math.max(0, vp.X - pxW)),
                math.clamp(ap.Y, 0, math.max(0, vp.Y - pxH)))
        end
        if fab then
            local fs = math.floor(52 * scale)
            fab.Size = UDim2.fromOffset(fs, fs)
            if fab.AbsoluteSize.X > 0 then
                local fp = fab.AbsolutePosition
                fab.Position = UDim2.fromOffset(
                    math.clamp(fp.X, 0, math.max(0, vp.X - fs)),
                    math.clamp(fp.Y, 0, math.max(0, vp.Y - fs)))
            end
        end
    end
    local function makeDraggable(handle)
        local dragging, dragStart, startPos
        handle.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = i.Position; startPos = main.Position
            end
        end)
        track(UserInputService.InputChanged:Connect(function(i)
            if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                local d = i.Position - dragStart
                main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
            end
        end))
        track(UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                if dragging then dragging = false; applyResponsive() end
            end
