-- ===== Responsive scaling (adapts to any device / resolution) =====
local DESIGN_W, DESIGN_H = 500, 512
local camera = workspace.CurrentCamera
local minimized = false
local fab  -- floating circular toggle button (created later)
local uiScale = Instance.new("UIScale")
uiScale.Parent = main

-- design-space height clamped so the scaled panel never overflows the screen
local function responsiveHeight()
    local vp = camera and camera.ViewportSize
    if not vp or vp.Y < 1 then return DESIGN_H end
    local s = uiScale.Scale > 0 and uiScale.Scale or 1
    return math.min(DESIGN_H, (vp.Y * 0.9) / s)
end

local function applyResponsive()
    local vp = camera and camera.ViewportSize
    if not vp or vp.X < 1 or vp.Y < 1 then return end
    -- scale relative to a 1366x768 baseline; smaller on phones, capped on huge screens
    local scale = math.clamp(math.min(vp.X / 1366, vp.Y / 768), 0.5, 1.2)
    uiScale.Scale = scale
    if not minimized then
        main.Size = UDim2.fromOffset(DESIGN_W, responsiveHeight())
    end
    -- keep the panel fully on-screen (using the scaled pixel footprint)
    local pxW = DESIGN_W * scale
    local pxH = (minimized and 46 or responsiveHeight()) * scale
    if main.AbsoluteSize.X > 0 then
        local ap = main.AbsolutePosition
        local x = math.clamp(ap.X, 0, math.max(0, vp.X - pxW))
        local y = math.clamp(ap.Y, 0, math.max(0, vp.Y - pxH))
        main.Position = UDim2.fromOffset(x, y)
    end
    -- scale + clamp the floating toggle button too
    if fab then
        local fs = math.floor(54 * scale)
        fab.Size = UDim2.fromOffset(fs, fs)
        if fab.AbsoluteSize.X > 0 then
            local fp = fab.AbsolutePosition
            fab.Position = UDim2.fromOffset(
                math.clamp(fp.X, 0, math.max(0, vp.X - fs)),
                math.clamp(fp.Y, 0, math.max(0, vp.Y - fs)))
        end
    end
end

