local function switchTab(tabName)
    activeTab = tabName
    pageTitle.Text = pageTitles[tabName]
    pageSub.Text = pageSubs[tabName]
    
    for name, btn in pairs(tabButtons) do
        local isActive = (name == tabName)
        local indicator = btn:FindFirstChild("Indicator")
        local label = btn:FindFirstChild("Label")
        if indicator then indicator.Visible = isActive end
        btn.BackgroundColor3 = isActive and Color3.fromRGB(18, 14, 15) or Color3.fromRGB(10, 10, 11)
        if label then
            label.TextColor3 = isActive and Color3.fromRGB(250, 250, 250) or Color3.fromRGB(150, 150, 160)
        end
    end
    
    for name, frame in pairs(pageFrames) do
        frame.Visible = (name == tabName)
    end
end

