-- Process current verification
local userInput = promptForKeyWindow()
local cleanKey = trim(userInput)

-- Build the secure cloud request parameters string
local payloadUrl = JNKIE_CHECK_API .. "?serviceId=" .. JNKIE_CONFIG.ServiceId .. "&apiKey=" .. JNKIE_CONFIG.ApiKey .. "&key=" .. cleanKey

local checkSuccess, apiResponse = pcall(game.HttpGet, game, payloadUrl)

-- Verify server token feedback validation data
if checkSuccess and (apiResponse:match("valid") or apiResponse:match("true") or apiResponse:match("success")) then
    print("Hudas Hub: Jnkie Verification Passed! Loading " .. route[1] .. " profile...")
    state.loaded[route[1]] = true
else
    local StarterGui = game:GetService("StarterGui")
    StarterGui:SetCore("SendNotification", {
        Title = "Hudas Hub",
        Text = "Authentication Failed: Invalid or Expired Key!",
        Duration = 5
    })
    return
end

-- Fetch and safely execute your script file from GitHub hosting
local ok, src = pcall(game.HttpGet, game, route[2])
if ok and src then
    local func, err = loadstring(src)
    if func then
        local execSuccess, execErr = pcall(func)
        if execSuccess then
            return
        end
        warn("Hudas Hub: Execution error inside script: " .. tostring(execErr))
    else
        warn("Hudas Hub: Syntax compilation error: " .. tostring(err))
    end
else
    warn("Hudas Hub: Failed to fetch the script from GitHub hosting.")
end

-- Reset the active loading state cache if the script fails out completely
state.loaded[route[1]] = nil
