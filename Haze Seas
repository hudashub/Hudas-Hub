-- ─── AUTO FARM LOOP ────────────────────────────────────────────────
local lastTween
local lastAttack = 0
local lastNpcCheck = 0
local lastQuestAccept = -999 -- cooldown after accepting quest to stop re-talking to NPC
local activeQ = nil
local highestQ = nil
local lastTimeHadQuest = tick()
local lastTargetName = nil
local lastQuestCompletedTime = 0
local needQuest = false



local function doAutoFarmStep()


    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if not State.AutoFarmLevel then 
        if lastTween then lastTween:Cancel(); lastTween = nil end
        clearBodyPos()          -- remove physics attachment so player can move freely
        root.Anchored = false
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.PlatformStand = false
        end
        currentTargetMob = nil  -- reset target

        -- Restore collision on all character parts
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    local orig = part:GetAttribute("OriginalCanCollide")
                    if orig ~= nil then
                        part.CanCollide = orig
                        part:SetAttribute("OriginalCanCollide", nil)
                    else
                        -- Fallback to standard R15/R6 collision parameters
                        local name = part.Name
                        if name == "UpperTorso" or name == "LowerTorso" or name == "Torso" or name == "Head" or name == "HumanoidRootPart" then
                            part.CanCollide = true
                        else
                            part.CanCollide = false
                        end
                    end
                end
            end
        end
        return 
    end

    -- Noclip: disable collision so player flies through walls to reach mobs
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            if part:GetAttribute("OriginalCanCollide") == nil then
                part:SetAttribute("OriginalCanCollide", part.CanCollide)
            end
            part.CanCollide = false
        end
    end


    -- Run quest check occasionally
    if tick() - lastNpcCheck > 0.5 then
        lastNpcCheck = tick()
        activeQ = getActiveQuest()
        highestQ = getHighestQuest()
        if activeQ then
            lastTimeHadQuest = tick()
            local questDone = activeQ.Progress >= activeQ.Target and activeQ.Target > 0
            if questDone then
                lastQuestCompletedTime = tick()
            end
        end
    end



    -- Display update
    if activeQ then
        questStatusLbl.Text = "Quest: " .. tostring(activeQ.NPCName) .. " (" .. tostring(activeQ.Progress) .. "/" .. tostring(activeQ.Target) .. ")"
    else
        questStatusLbl.Text = "Quest: None\nSeeking highest..."
    end

    -- 1. Check if we need to accept a higher quest or if quest is done
    needQuest = false


    if highestQ then
        if activeQ then
            -- We have an active quest. Check if it's complete.
            local questDone = activeQ.Progress >= activeQ.Target and activeQ.Target > 0

            -- Determine the level requirement of the current active quest
            local currentReq = -1
            local cleanTarget = activeQ.NPCName:lower():gsub("s$", ""):gsub("%s+", "")
            local npcZones2 = WS:FindFirstChild("NPC Zones")
            local mobFolders2 = {npcZones2, WS:FindFirstChild("Npc_Workspace")}
            for _, f in ipairs(mobFolders2) do
                if f then
                    for _, m in ipairs(f:GetDescendants()) do
                        if m:IsA("Model") and m:FindFirstChild("HumanoidRootPart") then
                            local mName = m.Name:lower():gsub("%s+", "")
                            if string.find(mName, cleanTarget) or string.find(cleanTarget, mName) then
                                local conf = m:FindFirstChild("Configuration")
                                local lvlVal = conf and conf:FindFirstChild("Level")
                                if lvlVal and lvlVal:IsA("IntValue") then
                                    currentReq = lvlVal.Value
                                    break
                                end
                            end
                        end
                    end
                    if currentReq ~= -1 then break end
                end
            end
            -- Fallback: treat current quest as highest so we don't cancel prematurely
            if currentReq == -1 then currentReq = highestQ.Req end

            local higherExists = highestQ.Req > currentReq

            -- Ensure AutoQuest is ON so the game auto-completes/turns in/repeats
            local pd2 = player:FindFirstChild("PlayerData")
            local aq2 = pd2 and pd2:FindFirstChild("AutoQuest")
            if aq2 and aq2.Value == false then
                local tq2 = RS:FindFirstChild("Replication")
                    and RS.Replication:FindFirstChild("ClientEvents")
                    and RS.Replication.ClientEvents:FindFirstChild("ToggleAutoQuest")
                if tq2 then tq2:FireServer() end
            end

            if higherExists then
                -- A better quest is available — cancel current quest
                -- and let the script go pick up the new one
                needQuest = true

                local questGui = player.PlayerGui:FindFirstChild("QuestGui")
                local mf2 = questGui and questGui:FindFirstChild("MainFrame")
                local closeBtn2 = mf2 and (mf2:FindFirstChild("CloseButton") or mf2:FindFirstChild("ExitButton") or mf2:FindFirstChild("X"))
                if closeBtn2 then
                    pcall(function()
                        for _, conn in ipairs(getconnections(closeBtn2.MouseButton1Click)) do conn:Fire() end
                        for _, conn in ipairs(getconnections(closeBtn2.Activated))        do conn:Fire() end
                    end)
                    task.wait(0.3)
                    currentTargetMob = nil -- reset target after quest change
                end
            end

        else
            -- No active quest at all — wait for grace period ONLY if we completed a quest recently
            -- otherwise go get one immediately
            if tick() - lastQuestCompletedTime > 5.0 then
                needQuest = true
            end
        end




        -- Close any open dialogue that says "already on quest" or "good luck"
        local tutorialGui = player.PlayerGui:FindFirstChild("Tutorial_Gui")
        if tutorialGui and tutorialGui.Enabled then
            local mainFrame = tutorialGui:FindFirstChild("MainFrame")
            local frame = mainFrame and mainFrame:FindFirstChild("Frame")
            local dialogueWrapper = frame and frame:FindFirstChild("DialogueWrapper")
            local diagLabel = dialogueWrapper and dialogueWrapper:FindFirstChild("Dialogue", true)
            if diagLabel and (diagLabel.Text:lower():match("already on quest") or diagLabel.Text:lower():match("good luck")) then
                local closeBtn = frame:FindFirstChild("CloseButton") or frame:FindFirstChild("Skip") or frame:FindFirstChild("Button")
                if closeBtn then
                    pcall(function()
                        for _, conn in ipairs(getconnections(closeBtn.MouseButton1Click)) do conn:Fire() end
                        for _, conn in ipairs(getconnections(closeBtn.MouseButton1Down))  do conn:Fire() end
                        for _, conn in ipairs(getconnections(closeBtn.Activated))         do conn:Fire() end
                    end)
                end
                task.wait(0.2)
            end
        end



        -- If we need a quest, walk to the NPC and accept it
        if needQuest then
            local npcModel = WS:FindFirstChild("Npc_Workspace")
                and WS.Npc_Workspace:FindFirstChild("QuestGivers")
                and WS.Npc_Workspace.QuestGivers:FindFirstChild(highestQ.NPC)
            if npcModel and npcModel:FindFirstChild("HumanoidRootPart") then
                local dest = npcModel.HumanoidRootPart.CFrame * CFrame.new(0, 0, -4) * CFrame.Angles(0, math.pi, 0)
                if (root.Position - dest.Position).Magnitude > 8 then
                    clearBodyPos()
                    -- let tweenTo handle anchoring/standing
                    if not (lastTween and lastTween.PlaybackState == Enum.PlaybackState.Playing) then
                        lastTween = tweenTo(dest)
                    end
                    return
                end

                if lastTween then lastTween:Cancel(); lastTween = nil end
                root.Anchored = true
                if char:FindFirstChild("Humanoid") then
                    char.Humanoid.PlatformStand = true
                end
                root.CFrame = dest


                -- Handle NPC dialogue to accept quest
                local tutorialGui2 = player.PlayerGui:FindFirstChild("Tutorial_Gui")
                if tutorialGui2 and tutorialGui2.Enabled then
                    local mainFrame2 = tutorialGui2:FindFirstChild("MainFrame")
                    local frame2 = mainFrame2 and mainFrame2:FindFirstChild("Frame")
                    local decFrame = frame2 and frame2:FindFirstChild("Decision")
                    if decFrame then
                        for _, choice in ipairs(decFrame:GetChildren()) do
                            if choice.Name == "Decision" then
                                local ansWrapper = choice:FindFirstChild("AnswerWrapper")
                                local ansLabel = ansWrapper and ansWrapper:FindFirstChild("Answer")
                                local button = choice:FindFirstChild("Button")
                                if ansLabel and button then
                                    local choiceText = ansLabel.Text
                                    local reqLvl = choiceText:match("Level (%d+)") or choiceText:match("Lv (%d+)") or choiceText:match("(%d+)")
                                    reqLvl = tonumber(reqLvl)
                                    if (reqLvl and reqLvl == highestQ.Req) or choiceText:lower() == "accept" then
                                        pcall(function()
                                            for _, conn in ipairs(getconnections(button.MouseButton1Click)) do conn:Fire() end
                                            for _, conn in ipairs(getconnections(button.MouseButton1Down))  do conn:Fire() end
                                            for _, conn in ipairs(getconnections(button.Activated))         do conn:Fire() end
                                        end)
                                        lastQuestAccept = tick() -- Reset talk debounce immediately upon acceptance to prevent re-talking!
                                        task.wait(0.2)
                                        return

                                    end
                                end
                            end
                        end
                    end
                end

                -- Close any open dialogue before firing prompt
                local tg = player.PlayerGui:FindFirstChild("Tutorial_Gui")
                if tg and tg.Enabled then
                    local mf3 = tg:FindFirstChild("MainFrame")
                    local fr3 = mf3 and mf3:FindFirstChild("Frame")
                    if fr3 then
                        -- Try decision close options first
                        local decFrame = fr3:FindFirstChild("Decision")
                        if decFrame then
                            for _, choice in ipairs(decFrame:GetChildren()) do
                                if choice.Name == "Decision" then
                                    local ansWrapper = choice:FindFirstChild("AnswerWrapper")
                                    local ansLabel = ansWrapper and ansWrapper:FindFirstChild("Answer")
                                    local button = choice:FindFirstChild("Button")
                                    if ansLabel and button then
                                        local txt = ansLabel.Text:lower()
                                        if string.find(txt, "close") or string.find(txt, "deny") or string.find(txt, "cancel") then
                                            pcall(function()
                                                for _, conn in ipairs(getconnections(button.MouseButton1Click)) do conn:Fire() end
                                                for _, conn in ipairs(getconnections(button.MouseButton1Down))  do conn:Fire() end
                                                for _, conn in ipairs(getconnections(button.Activated))         do conn:Fire() end
                                            end)
                                            task.wait(0.2)
                                        end
                                    end
                                end
                            end
                        end

                        -- Try standard skip/next/ok buttons
                        local cb3 = fr3:FindFirstChild("CloseButton") or fr3:FindFirstChild("Skip") or fr3:FindFirstChild("Next") or fr3:FindFirstChild("Ok")
                        if cb3 then
                            pcall(function()
                                for _, c in ipairs(getconnections(cb3.MouseButton1Click)) do c:Fire() end
                                for _, c in ipairs(getconnections(cb3.Activated))         do c:Fire() end
                            end)
                            task.wait(0.3)
                        else
                            -- Fallback: click Dialogue text frame itself to advance/dismiss conversation
                            local dialogueWrapper = fr3:FindFirstChild("DialogueWrapper")
                            local diagLabel = dialogueWrapper and dialogueWrapper:FindFirstChild("Frame") and dialogueWrapper.Frame:FindFirstChild("Dialogue")
                            if diagLabel then
                                pcall(function()
                                    for _, conn in ipairs(getconnections(diagLabel.MouseButton1Click)) do conn:Fire() end
                                    for _, conn in ipairs(getconnections(dialogueWrapper.MouseButton1Click)) do conn:Fire() end
                                end)
                                task.wait(0.3)
                            end
                        end
                    end
                end



                -- Only fire prompt if quest dialogue is NOT already open and cooldown has passed
                local tutorialGuiOpen = player.PlayerGui:FindFirstChild("Tutorial_Gui") and player.PlayerGui.Tutorial_Gui.Enabled
                if not tutorialGuiOpen and tick() - lastQuestAccept > 3 then
                    local prompt = npcModel:FindFirstChild("Clicker")
                        and npcModel.Clicker:FindFirstChildWhichIsA("ProximityPrompt")
                    if prompt then
                        fireproximityprompt(prompt)
                        lastQuestAccept = tick()
                        task.wait(0.5)
                    end
                end
                return

            end
        end
    end


    -- 2. Farm Active Quest Target (only if we don't currently need to go to NPC)
    if not needQuest and (activeQ or lastTargetName) then

        if activeQ then
            lastTargetName = activeQ.NPCName
        end
        
        -- Unanchor and disable PlatformStand so animations play and weapon hits register normally!
        root.Anchored = false
        if char:FindFirstChild("Humanoid") then
            char.Humanoid.PlatformStand = false
        end
        if lastTween then 
            lastTween:Cancel() 
            lastTween = nil 
        end



        -- Close any lingering NPC dialogue so we don't get stuck at the NPC
        local tgFarm = player.PlayerGui:FindFirstChild("Tutorial_Gui")
        if tgFarm and tgFarm.Enabled then
            local mfFarm = tgFarm:FindFirstChild("MainFrame")
            local frFarm = mfFarm and mfFarm:FindFirstChild("Frame")
            if frFarm then
                -- 1. Try decision close options first (e.g. [CLOSE])
                local decFrame = frFarm:FindFirstChild("Decision")
                if decFrame then
                    for _, choice in ipairs(decFrame:GetChildren()) do
                        if choice.Name == "Decision" then
                            local ansWrapper = choice:FindFirstChild("AnswerWrapper")
                            local ansLabel = ansWrapper and ansWrapper:FindFirstChild("Answer")
                            local button = choice:FindFirstChild("Button")
                            if ansLabel and button then
                                local txt = ansLabel.Text:lower()
                                if string.find(txt, "close") or string.find(txt, "deny") or string.find(txt, "cancel") then
                                    pcall(function()
                                        for _, conn in ipairs(getconnections(button.MouseButton1Click)) do conn:Fire() end
                                        for _, conn in ipairs(getconnections(button.MouseButton1Down))  do conn:Fire() end
                                        for _, conn in ipairs(getconnections(button.Activated))         do conn:Fire() end
                                    end)
                                    task.wait(0.2)
                                end
                            end
                        end
                    end
                end

                -- 2. Try standard skip/next/ok buttons
                local cbFarm = frFarm:FindFirstChild("CloseButton") or frFarm:FindFirstChild("Skip") or frFarm:FindFirstChild("Next") or frFarm:FindFirstChild("Ok")
                if cbFarm then
                    pcall(function()
                        for _, c in ipairs(getconnections(cbFarm.MouseButton1Click)) do c:Fire() end
                        for _, c in ipairs(getconnections(cbFarm.Activated))         do c:Fire() end
                    end)
                    task.wait(0.2)
                else
                    -- Fallback: click dialogue label to advance/dismiss lingering text
                    local dialogueWrapper = frFarm:FindFirstChild("DialogueWrapper")
                    local diagLabel = dialogueWrapper and dialogueWrapper:FindFirstChild("Frame") and dialogueWrapper.Frame:FindFirstChild("Dialogue")
                    if diagLabel then
                        pcall(function()
                            for _, conn in ipairs(getconnections(diagLabel.MouseButton1Click)) do conn:Fire() end
                            for _, conn in ipairs(getconnections(dialogueWrapper.MouseButton1Click)) do conn:Fire() end
                        end)
                        task.wait(0.2)
                    end
                end
            end
            
            -- Only return/wait if dialogue remains open
            if tgFarm.Enabled then
                return
            end
        end



        -- Enable built-in AutoQuest if off
        local pd = player:FindFirstChild("PlayerData")
        local aq = pd and pd:FindFirstChild("AutoQuest")
        if aq and aq.Value == false then
            local tq = RS:FindFirstChild("Replication") and RS.Replication:FindFirstChild("ClientEvents") and RS.Replication.ClientEvents:FindFirstChild("ToggleAutoQuest")
            if tq then tq:FireServer() end
        end

        -- Persistent target handling: keep current mob until it dies
        if not currentTargetMob or not currentTargetMob:FindFirstChild("Humanoid") or currentTargetMob.Humanoid.Health <= 0 then
            local targetName = activeQ and activeQ.NPCName or lastTargetName

            local npcWorkspace = WS:FindFirstChild("Npc_Workspace")
            local questGiversFolder = npcWorkspace and npcWorkspace:FindFirstChild("QuestGivers")

            -- Normalize: lowercase, strip spaces, strip trailing 's' (plural → singular)
            local cleanTarget  = targetName:lower():gsub("%s+", ""):gsub("s$", "")
            local bestDist = math.huge
            local bestMob  = nil

            -- Search all workspace descendants — mobs can be anywhere in the map
            for _, m in ipairs(WS:GetDescendants()) do
                -- Skip QuestGiver NPCs entirely
                if questGiversFolder and m:IsDescendantOf(questGiversFolder) then continue end
                if m:IsA("Model") and m:FindFirstChild("HumanoidRootPart") then
                    -- Normalize mob name the same way (strip plural s too)
                    local mName = m.Name:lower():gsub("%s+", ""):gsub("s$", "")
                    -- Match: mob name equals OR contains the quest target name
                    local nameMatch = mName == cleanTarget
                        or string.find(mName, cleanTarget, 1, true) ~= nil
                    if nameMatch then
                        local hum = m:FindFirstChild("Humanoid")
                        -- MaxHealth > 0 filters out non-combat NPCs (quest givers = 0)
                        if hum and hum.Health > 0 and hum.MaxHealth > 0 then
                            local d = (root.Position - m.HumanoidRootPart.Position).Magnitude
                            if d < bestDist then
                                bestDist = d
                                bestMob = m
                            end
                        end
                    end
                end
            end
            currentTargetMob = bestMob
        end
        local targetMob = currentTargetMob
        if targetMob then
            local mobRoot = targetMob.HumanoidRootPart
            local targetPos = mobRoot.Position
            
            -- If we are far from the target mob, tween to it smoothly at 220 studs/sec
            -- instead of instant-teleporting (bypasses anti-cheat & makes camera smooth)
            local dist = (root.Position - targetPos).Magnitude
            if dist > 20 then
                local wantedPos
                if State.FarmPosition == "Above" then
                    wantedPos = targetPos + Vector3.new(0, State.FarmDistance, 0)
                elseif State.FarmPosition == "Under" then
                    wantedPos = targetPos + Vector3.new(0, -State.FarmDistance, 0)
                else -- Behind
                    wantedPos = (mobRoot.CFrame * CFrame.new(0, 0, State.FarmDistance)).Position
                end
                local targetCF = CFrame.new(wantedPos, targetPos)
                
                if not (lastTween and lastTween.PlaybackState == Enum.PlaybackState.Playing) then
                    lastTween = tweenTo(targetCF, 220) -- 220 studs/second speed
                end
                return
            end
            
            if lastTween then 
                lastTween:Cancel() 
                lastTween = nil 
            end
            
            -- Just fire the attack here on the 10Hz tick if AutoAttack is enabled

            if State.AutoAttack and tick() - lastAttack > 0.15 then
                lastAttack = tick()
                -- Gate attack on Dialogue not open and mob within 25 studs range
                local tgOpen = player.PlayerGui:FindFirstChild("Tutorial_Gui") and player.PlayerGui.Tutorial_Gui.Enabled
                local distToMob = (root.Position - mobRoot.Position).Magnitude
                if not tgOpen and distToMob < 25 then
                    -- Equip weapon if none is held
                    local char2 = player.Character
                    local heldTool = char2 and char2:FindFirstChildWhichIsA("Tool")
                    if not heldTool then
                        local bp2 = player:FindFirstChild("Backpack")
                        local hum2 = char2 and char2:FindFirstChild("Humanoid")
                        if bp2 and hum2 then
                            local anyTool = bp2:FindFirstChildWhichIsA("Tool")
                            if anyTool then hum2:EquipTool(anyTool) end
                        end
                    end
                    -- Attack directly via tool activation (no screen click needed)
                    local finalTool = char2 and char2:FindFirstChildWhichIsA("Tool")
                    if finalTool then
                        finalTool:Activate()
                    end
                end
            end
        else
            -- No mob — let player move freely
            root.Anchored = false
        end
    else
        root.Anchored = false
    end
end


local function doCombatFeatures()
    if State.AutoFarmLevel and needQuest then
        return
    end

    local char = player.Character
    if not char then return end


    -- Auto Weapon
    if State.SelectedWeapon and State.SelectedWeapon ~= "None" then
        if not char:FindFirstChild(State.SelectedWeapon) then
            local bp = player:FindFirstChild("Backpack")
            local tool = bp and bp:FindFirstChild(State.SelectedWeapon)
            local hum = char:FindFirstChild("Humanoid")
            if tool and hum then
                hum:EquipTool(tool)
            end
        end
    end

    -- Find nearest alive mob to gate attacks/skills on proximity
    local nearestMobDist = math.huge
    local charRoot = char:FindFirstChild("HumanoidRootPart")
    if charRoot then
        local checkFolders = {WS:FindFirstChild("NPC Zones"), WS:FindFirstChild("Npc_Workspace")}
        local questGiversF = WS:FindFirstChild("Npc_Workspace") and WS.Npc_Workspace:FindFirstChild("QuestGivers")
        for _, f in ipairs(checkFolders) do
            if f then
                for _, m in ipairs(f:GetDescendants()) do
                    if questGiversF and m:IsDescendantOf(questGiversF) then continue end
                    if m:IsA("Model") and m ~= char then
                        local hum = m:FindFirstChild("Humanoid")
                        local mRoot = m:FindFirstChild("HumanoidRootPart")
                        if hum and mRoot and hum.Health > 0 and hum.MaxHealth > 0 then
                            local d = (charRoot.Position - mRoot.Position).Magnitude
                            if d < nearestMobDist then nearestMobDist = d end
                        end
                    end
                end
            end
        end
    end
    local MOB_ATTACK_RANGE = 30 -- studs — only attack/use skills within this range
    local mobNearby = nearestMobDist <= MOB_ATTACK_RANGE

    -- Gate all general combat inputs on Dialogue not open
    local tgOpen = player.PlayerGui:FindFirstChild("Tutorial_Gui") and player.PlayerGui.Tutorial_Gui.Enabled
    if tgOpen then return end

    -- Auto Attack (only when mob is nearby)
    if State.AutoAttack and not State.AutoFarmLevel and mobNearby then
        local tool = char:FindFirstChildWhichIsA("Tool")
        if tool then
            tool:Activate()
        else
            VR:ClickButton1(Vector2.new(0,0))
        end
    end

    -- Auto Haki / Observation
    local pd = player:FindFirstChild("PlayerData")
    if pd then
        if State.AutoBuso then
            if not char:FindFirstChild("FakeLimb") then
                local VIM = game:GetService("VirtualInputManager")
                VIM:SendKeyEvent(true, Enum.KeyCode.J, false, game)
                task.wait(0.05)
                VIM:SendKeyEvent(false, Enum.KeyCode.J, false, game)
                task.wait(0.2)
            end
        end
        if State.AutoObservation then
            local obsBuff = pd:FindFirstChild("Buffs") and pd.Buffs:FindFirstChild("ObsHakiBuff")
            local ownObs = pd:FindFirstChild("Haki") and pd.Haki:FindFirstChild("OwnHaki")
            if ownObs and ownObs.Value == true and obsBuff and obsBuff.Value == 0 then
                local VIM = game:GetService("VirtualInputManager")
                VIM:SendKeyEvent(true, Enum.KeyCode.K, false, game)
                task.wait(0.05)
                VIM:SendKeyEvent(false, Enum.KeyCode.K, false, game)
                task.wait(0.2)
            end
        end

        -- Auto Skills: fire only selected keys when a mob is nearby
        if State.AutoSkills and #State.SkillKeys > 0 and mobNearby then
            local VIM = game:GetService("VirtualInputManager")
            
            -- Resolve aim target (current locked farm mob or nearest alive mob)
            local targetMob = currentTargetMob
            if not targetMob then
                local nearest = nil
                local dist = math.huge
                local charRoot = char:FindFirstChild("HumanoidRootPart")
                if charRoot then
                    local checkFolders = {WS:FindFirstChild("NPC Zones"), WS:FindFirstChild("Npc_Workspace")}
                    local questGiversF = WS:FindFirstChild("Npc_Workspace") and WS.Npc_Workspace:FindFirstChild("QuestGivers")
                    for _, f in ipairs(checkFolders) do
                        if f then
                            for _, m in ipairs(f:GetDescendants()) do
                                if questGiversF and m:IsDescendantOf(questGiversF) then continue end
                                if m:IsA("Model") and m ~= char then
                                    local hum = m:FindFirstChild("Humanoid")
                                    local mRoot = m:FindFirstChild("HumanoidRootPart")
                                    if hum and mRoot and hum.Health > 0 and hum.MaxHealth > 0 then
                                        local d = (charRoot.Position - mRoot.Position).Magnitude
                                        if d < dist then
                                            dist = d
                                            nearest = m
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
                targetMob = nearest
            end

            local keyMap = {
                Z="Z", X="X", C="C", V="V", Q="Q", E="E",
                R="R", F="F", G="G", T="T",
                ["1"]="One", ["2"]="Two", ["3"]="Three", ["4"]="Four",
            }
            for _, k in ipairs(State.SkillKeys) do
                local enumName = keyMap[k]
                local keyCode = enumName and Enum.KeyCode[enumName]
                if keyCode then
                    -- Auto-Aim: Warp the mouse to the mob's screen position right before casting
                    if targetMob and targetMob:FindFirstChild("HumanoidRootPart") then
                        local camera = workspace.CurrentCamera
                        if camera then
                            local screenPos, onScreen = camera:WorldToScreenPoint(targetMob.HumanoidRootPart.Position)
                            if onScreen then
                                VIM:SendMouseMoveEvent(screenPos.X, screenPos.Y, game)
                            end
                        end
                    end
                    
                    VIM:SendKeyEvent(true,  keyCode, false, game)
                    task.wait(0.05)
                    VIM:SendKeyEvent(false, keyCode, false, game)
                    task.wait(0.12) -- grace delay for the game to register mouse aim direction
                end
            end
        end

    end


    -- Attachment Spoofing Kill Aura / Hitbox Expander
    local tool = char:FindFirstChildWhichIsA("Tool")
    if State.ExpandHitbox and tool then
        -- Find target mob (closest alive mob within 100 studs)
        local targetMob = nil
        local dist = math.huge
        local npcZones = WS:FindFirstChild("NPC Zones")
        local mobFolders = {npcZones, WS:FindFirstChild("Npc_Workspace")}
        
        for _, folder in ipairs(mobFolders) do
            if folder then
                for _, m in ipairs(folder:GetDescendants()) do
                    if m:IsA("Model") and m:FindFirstChild("Humanoid") and m:FindFirstChild("HumanoidRootPart") then
                        local hum = m.Humanoid
                        if hum.Health > 0 and m ~= char then
                            local d = (char.HumanoidRootPart.Position - m.HumanoidRootPart.Position).Magnitude
                            if d < 100 and d < dist then
                                dist = d
                                targetMob = m
                            end
                        end
                    end
                end
            end
        end

        if targetMob then
            for _, c in ipairs(tool:GetDescendants()) do
                if c:IsA("Attachment") and c.Name == "DmgPoint" then
                    if not c:GetAttribute("OrigPos") then
                        c:SetAttribute("OrigPos", c.Position)
                    end
                    local parent = c.Parent
                    if parent and parent:IsA("BasePart") then
                        c.Position = parent.CFrame:PointToObjectSpace(targetMob.HumanoidRootPart.Position)
                    end
                end
            end
        end
    else
        -- Revert attachment positions if disabled
        if tool then
            for _, c in ipairs(tool:GetDescendants()) do
                if c:IsA("Attachment") and c.Name == "DmgPoint" then
                    local orig = c:GetAttribute("OrigPos")
                    if orig then
                        c.Position = orig
                        c:SetAttribute("OrigPos", nil)
                    end
                end
            end
        end
    end
end

