    chip.Size = widthUDim; chip.AutoButtonColor = false; chip.Font = Enum.Font.GothamBold
    chip.TextSize = 11; chip.Text = text; chip.LayoutOrder = order; chip.Parent = parent
    Instance.new("UICorner", chip).CornerRadius = UDim.new(0, 6)
    local cs = Instance.new("UIStroke", chip); cs.Color = COL.red; cs.Thickness = 1
    local function render()
        local on = stateTbl[stateKey]
