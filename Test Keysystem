-- Helper functions for execution environment safety
local function trim(v)
    return tostring(v or ""):match("^%s*(.-)%s*$") or ""
end

local function envOf(fn, ...)
    if type(fn) ~= "function" then return nil end
    local ok, env = pcall(fn, ...)
    return ok and type(env) == "table" and env or nil
end

local genv = envOf(getgenv)

-- Check if the current game is supported by your router
local route = routes[game.PlaceId] or routes[game.GameId]
if not route then
    warn("Hudas Hub: Game ID (" .. tostring(game.PlaceId) .. ") is not currently supported!")
    return
end

-- Prevent double-loading the exact script profile in the same engine session
