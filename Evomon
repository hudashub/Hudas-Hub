-- best-effort level read (talent/shiny are impossible; level usually is too,
-- but try a few sources and cache the result per-uid so it's cheap)
local levelCache = {}
local function resolveLevel(model, uid)
    if levelCache[uid] ~= nil then return levelCache[uid] or nil end
    local lv
    for _, k in ipairs({ "level", "Level", "lv", "Lv", "petLevel" }) do
        local v = model:GetAttribute(k); if type(v) == "number" then lv = v break end
    end
    if not lv then
        for _, d in ipairs(model:GetDescendants()) do
            if d:IsA("TextLabel") then
                local m = tostring(d.Text):match("Lv%.?%s*(%d+)")
                if m then lv = tonumber(m); break end
            end
        end
    end
    levelCache[uid] = lv or false
    return lv
end

local function myRoot()
    local ch = LocalPlayer.Character
    return ch and ch:FindFirstChild("HumanoidRootPart"), ch and ch:FindFirstChildOfClass("Humanoid")
end

-- enumerate creatures of a type within maxDist; returns array {uid,model,part,pos,dist,cfgId}
local function gather(ctype, maxDist, speciesText)
    local out = {}
    local cache = creatureCache()
    if not cache then return out end
    local root = myRoot()
    if not root then return out end
    local myPos = root.Position
    for _, m in ipairs(cache:GetChildren()) do
        if m:GetAttribute("type") == ctype then
            local ok, pivot = pcall(function() return m:GetPivot() end)
            if ok then
                local pos = pivot.Position
                local dist = (pos - myPos).Magnitude
                if dist <= maxDist then
                    local cfgId = m:GetAttribute("configId")
                    local nm = (ctype == TYPE_WILD) and petName(cfgId) or npcName(cfgId)
                    if speciesText == "" or string.find(string.lower(nm), string.lower(speciesText), 1, true) then
                        local part = m:FindFirstChildWhichIsA("BasePart", true) or (m.PrimaryPart)
                        out[#out + 1] = { uid = m.Name, model = m, part = part, pos = pos,
                                          dist = dist, cfgId = cfgId, name = nm }
                    end
                end
            end
        end
    end
    table.sort(out, function(a, b) return a.dist < b.dist end)
    return out
end

local function nearestWild()
    local list = gather(TYPE_WILD, activeMaxDist(), speciesFilter)
    return list[1]
end

