-- Executor reloads do NOT kill the previous run's event connections / loops,
-- so an old auto-bidder keeps firing in the background (bidding even when the
-- new GUI shows it OFF). We register everything global and tear the old one
-- down on each load.
if _G.__SH_AF_CLEANUP then pcall(_G.__SH_AF_CLEANUP) end
local _CONNS, _THREADS = {}, {}
local function track(conn) table.insert(_CONNS, conn); return conn end
local function trackThread(t) table.insert(_THREADS, t); return t end
_G.__SH_AF_CLEANUP = function()
    for _, c in ipairs(_CONNS)   do pcall(function() c:Disconnect() end) end
    for _, t in ipairs(_THREADS) do pcall(function() task.cancel(t) end) end
    _CONNS, _THREADS = {}, {}
end

