    SubmitBtn.MouseLeave:Connect(function()
        TweenService:Create(SubmitBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(200, 20, 20)}):Play()
    end)
    
    -- Clipboard logic to copy the dynamic redirect destination link
    GetKeyBtn.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(JNKIE_GET_KEY_URL)
            GetKeyBtn.Text = "LINK COPIED TO CLIPBOARD!"
            task.wait(1.5)
            GetKeyBtn.Text = "GET KEY (LOOTLABS)"
