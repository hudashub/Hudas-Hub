local function collectAllMyCarryables(garageModel)
    local carry = WS:FindFirstChild("_Carryables")
    if not carry or not rootPart or not garageModel then return end
    
    local garagePos = garageModel:GetPivot().Position
    local startCollect = os.clock()
    
    -- Ensure vehicle is spawned outside (25 studs away from active auction)
    ensureVehicleNearby(garageModel)
    
    -- Loop until no owned carryables are left within 80 studs, or timeout (15s)
    while os.clock() - startCollect < 15 and State.AutoContainerFarm do
        ensureVehicleNearby(garageModel)
        local targets = {}
        for _, item in ipairs(carry:GetChildren()) do
            if isMine(item) then
                local base = item:FindFirstChild("Base") or item:FindFirstChildWhichIsA("BasePart")
                local pos = base and base.Position or item:GetPivot().Position
                local dist = (pos - garagePos).Magnitude
                if dist <= 80 then
                    local prompt = nil
                    for _, d in ipairs(item:GetDescendants()) do
                        if d:IsA("ProximityPrompt") and GRAB_PROMPTS[d.Name] and d.Enabled then
                            prompt = d
                            break
                        end
                    end
                    if prompt then
                        local shouldGrab = true
                        if prompt.Name == "PickupPrompt" and not passesFilters(item) then
                            shouldGrab = false
                        end
                        if shouldGrab then
                            table.insert(targets, {
                                item = item,
                                prompt = prompt,
                                pos = pos
                            })
                        end
                    end
                end
            end
        end
        
        if #targets == 0 then
            break -- No items left to collect!
        end
        
        -- Teleport to and collect each target
        for _, target in ipairs(targets) do
            if not State.AutoContainerFarm then break end
            
            while State.SpawningVehicle do task.wait(0.05) end
            State.status = "🤲 Teleporting to item: " .. target.item.Name
            rootPart.CFrame = CFrame.new(target.pos + Vector3.new(0, 1.5, 0))
            task.wait(0.15)
            
            pcall(function() fireproximityprompt(target.prompt) end)
            task.wait(0.2)
        end
        task.wait(0.3)
    end
end

local function runContainerFarmLoop()
    if containerFarmThread then pcall(task.cancel, containerFarmThread) end
    containerFarmThread = task.spawn(function()
        while State.AutoContainerFarm do
            -- Wait if active bidding is currently in progress
            if State.inAuction then
                State.status = "⏳ Active bidding in progress..."
                task.wait(1.0)
                continue
            end

            -- Double check we are not sitting before searching or teleporting
            local hum = character and character:FindFirstChildOfClass("Humanoid")
            if hum and hum.SeatPart then
                State.status = "🚶 Exiting vehicle first..."
                local exitStart = os.clock()
                while hum.SeatPart and (os.clock() - exitStart) < 4 do
                    hum.Sit = false
                    hum.Jump = true
                    local seat = hum.SeatPart
                    if seat then
                        local weld = seat:FindFirstChild("SeatWeld")
                        if weld then pcall(function() weld:Destroy() end) end
                    end
                    task.wait(0.2)
                end
                task.wait(1.5)
            end

            State.status = "🔍 Searching for selected containers..."
            local target = getClosestContainer()
            if target then
                local oldBid = State.AutoBidWin
                local oldPickup = State.AutoPickup
                State.AutoBidWin = true
                State.AutoPickup = true
                
                -- Teleport to the prompt part
                State.status = "✈️ Teleporting to " .. target.model.Name
                if rootPart then
                    while State.SpawningVehicle do task.wait(0.05) end
                    rootPart.CFrame = target.part.CFrame + Vector3.new(0, 2, 0)
                end
                task.wait(0.5)
                
                -- Fire prompt
                State.status = "🏁 Starting auction on " .. target.model.Name
                pcall(function() fireproximityprompt(target.prompt) end)
                task.wait(1.5)
                
                -- Wait for auction to begin
                local startWait = os.clock()
                while not State.inAuction and (os.clock() - startWait) < 8 and State.AutoContainerFarm do
                    task.wait(0.2)
                end
                
                if State.inAuction and State.AutoContainerFarm then
                    State.status = "🔨 Bidding on " .. target.model.Name
                    -- Wait for auction to end
                    while State.inAuction and State.AutoContainerFarm do
                        task.wait(0.5)
                    end
                    
                    if State.AutoContainerFarm then
                        State.status = "✅ Auction won/ended. Collecting items..."
                        task.wait(1.5)
                        collectAllMyCarryables(target.model)
                    end
                else
                    State.status = "⚠️ Auction failed to start"
                end
                
                if State.AutoContainerFarm then
                    -- Vehicle Unload Phase
                    local veh = getMyVehicle()
                    if veh then
                        local promptLocation = veh:FindFirstChild("PromptLocation", true)
                        local prompt = promptLocation and promptLocation:FindFirstChild("VehiclePrompt")
                        local driveSeat = veh:FindFirstChild("DriveSeat", true)
                        
                        if prompt and driveSeat then
                            State.status = "✈️ Teleporting to vehicle..."
                            if rootPart then
                                rootPart.CFrame = driveSeat.CFrame + Vector3.new(0, 2, 0)
                            end
                            task.wait(0.3)
                            
                            State.status = "🚛 Entering vehicle..."
                            pcall(function() fireproximityprompt(prompt) end)
                            task.wait(0.8)
                            
                            -- Verify we are sitting in the vehicle seat
                            local hum = character and character:FindFirstChildOfClass("Humanoid")
                            if hum and hum.SeatPart and hum.SeatPart:IsDescendantOf(veh) then
                                State.status = "📦 Unloading vehicle..."
                                doUnloadPass()
                                task.wait(1)
                            else
                                State.status = "⚠️ Failed to enter vehicle"
                            end
                            
                            -- Jump out and verify seat is cleared
                            if hum then
                                local exitStart = os.clock()
                                while hum.SeatPart and (os.clock() - exitStart) < 4 do
                                    hum.Sit = false
                                    hum.Jump = true
                                    local seat = hum.SeatPart
                                    if seat then
                                        local weld = seat:FindFirstChild("SeatWeld")
                                        if weld then pcall(function() weld:Destroy() end) end
                                    end
                                    task.wait(0.2)
                                end
                            end
                            State.status = "🚶 Exited vehicle"
                            task.wait(2)
                        else
                            State.status = "⚠️ Vehicle seat or prompt not found"
                        end
                    else
                        State.status = "⚠️ No vehicle spawned"
                    end
                end
                
                -- Restore previous states
                State.AutoBidWin = oldBid
                State.AutoPickup = oldPickup
            else
                State.status = "📭 No available containers found. Waiting..."
            end
            task.wait(3)
        end
    end)
    trackThread(containerFarmThread)
end

