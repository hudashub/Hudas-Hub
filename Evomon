        sl.Font = Enum.Font.GothamMedium; sl.Text = "Playback speed"
        sl.TextColor3 = COL.sub; sl.TextSize = 11; sl.TextXAlignment = Enum.TextXAlignment.Left
        sl.LayoutOrder = 2; sl.Parent = fbBody
        makeSegment(fbBody, 3, battleSpeedMul, {
