local function getAllMutations()
    local list = { "All" }
    local seen = {}
    
    if MutatorMod then
        if type(MutatorMod.Mutations) == "table" then
            for _, m in ipairs(MutatorMod.Mutations) do
                if m.Name and not seen[m.Name] then
                    seen[m.Name] = true
                    table.insert(list, m.Name)
                end
            end
        end
        if type(MutatorMod.TimeMutations) == "table" then
            for _, m in ipairs(MutatorMod.TimeMutations) do
                if m.Name and not seen[m.Name] then
                    seen[m.Name] = true
                    table.insert(list, m.Name)
                end
            end
        end
        if type(MutatorMod.EventMutations) == "table" then
            for _, m in ipairs(MutatorMod.EventMutations) do
                if m.Name and not seen[m.Name] then
                    seen[m.Name] = true
                    table.insert(list, m.Name)
                end
            end
        end
        if type(MutatorMod._kinds) == "table" then
            for name, _ in pairs(MutatorMod._kinds) do
                if not seen[name] then
                    seen[name] = true
                    table.insert(list, name)
                end
            end
        end
    end
    
    if #list <= 1 then
        local defaults = { "Silver", "Gold", "Corrupted", "Diamond", "Gem", "Chrome", "Hologram", "Black", "Void", "Secret", "Rainbow", "Cobwebbed", "Antique", "Ancient", "Timeless", "Moonlit", "Firefly", "Wet", "Shocked", "Pure", "Spotless", "Tiny", "Huge" }
        for _, name in ipairs(defaults) do
            table.insert(list, name)
        end
    end
    table.sort(list)
    for i, v in ipairs(list) do
        if v == "All" then
            table.remove(list, i)
            break
        end
    end
    table.insert(list, 1, "All")
    return list
end

