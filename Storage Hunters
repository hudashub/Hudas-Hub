local function performTeleport(placeName)
    if not rootPart then
        State.status = "⚠️ Character RootPart not found"
        return
    end
    
    local targetCF = nil
    
    if placeName == "My Plot" then
        local plot = State.myPlot or findMyPlot()
        if plot then
            local base = plot:FindFirstChild("Base")
            local floor = base and base:FindFirstChild("Floor")
            if floor then
                -- Place character exactly 105 studs along the front Vector (facing the plot)
                local standPos = (floor.CFrame * Vector3.new(0, 3, -105))
                targetCF = CFrame.new(standPos, floor.Position)
            else
                local pivot = plot:GetPivot()
                targetCF = CFrame.new(pivot.Position + Vector3.new(0, 3, -105), pivot.Position)
            end
        else
            State.status = "⚠️ My Plot not found"
            return
        end
    elseif placeName == "Shopping Mall" then
        local pos = TeleportLocations["Shopping Mall"]
        if pos then
            targetCF = CFrame.new(pos + Vector3.new(0, 3, 0))
        end
    else
        -- Search for NPC in the area first
        local npc = findNPCInArea(placeName)
        if npc then
            local pivot = npc:GetPivot()
            -- Teleport 6 studs in front of the NPC, facing them
            local standPos = pivot.Position + pivot.LookVector * 6 + Vector3.new(0, 1, 0)
            targetCF = CFrame.new(standPos, pivot.Position)
        else
            -- Fallback: find closest container to the area's center
            local center = getAreaCenter(placeName)
            local closestGarage = center and getClosestGarageTo(center)
            if closestGarage then
                local gPivot = closestGarage:GetPivot()
                targetCF = CFrame.new(gPivot.Position + Vector3.new(0, 3, 0))
            else
                -- Ultimate fallback: hardcoded vector
                local pos = TeleportLocations[placeName]
                if pos then
                    targetCF = CFrame.new(pos + Vector3.new(0, 3, 0))
                end
            end
        end
    end
    
    if targetCF then
        State.status = "✈️ Teleported to " .. placeName
        rootPart.CFrame = targetCF
    else
        State.status = "⚠️ Teleport failed for " .. tostring(placeName)
    end
end

