local DESIGN_W, DESIGN_H = 760, 485
local camera = workspace.CurrentCamera
local fab

local MF = Instance.new("Frame")
local uiScale = Instance.new("UIScale", MF)

local function responsiveHeight()
    local vp = camera and camera.ViewportSize
    if not vp or vp.Y < 1 then return DESIGN_H end
    local s = uiScale.Scale > 0 and uiScale.Scale or 1
    return math.min(DESIGN_H, (vp.Y * 0.92) / s)
end

local function applyResponsive()
    local vp = camera and camera.ViewportSize
    if not vp or vp.X < 1 or vp.Y < 1 then return end
    uiScale.Scale = math.clamp(math.min(vp.X / 1366, vp.Y / 768), 0.5, 1.15)
    MF.Size = UDim2.fromOffset(DESIGN_W, responsiveHeight())
    if MF.AbsoluteSize.X > 0 then
        local as2, ap2 = MF.AbsoluteSize, MF.AbsolutePosition
        local cx = math.clamp(ap2.X, 0, math.max(0, vp.X - as2.X))
        local cy = math.clamp(ap2.Y, 0, math.max(0, vp.Y - as2.Y))
        if math.abs(cx - ap2.X) > 0.5 or math.abs(cy - ap2.Y) > 0.5 then
            MF.Position = UDim2.fromOffset(cx + as2.X*0.5, cy + as2.Y * 0.5)
        end
    end
    if fab and fab.AbsoluteSize.X > 0 then
        local fs = math.floor(52 * uiScale.Scale)
        fab.Size = UDim2.fromOffset(fs, fs)
        local px = fab.Position.X.Offset
        local py = fab.Position.Y.Offset
        local cx = math.clamp(px, fs * 0.5, vp.X - fs * 0.5)
        local cy = math.clamp(py, fs * 0.5, vp.Y - fs * 0.5)
        if math.abs(cx - px) > 0.5 or math.abs(cy - px) > 0.5 then
            fab.Position = UDim2.fromOffset(cx, cy)
        end
    end
end

track(camera:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsive))

