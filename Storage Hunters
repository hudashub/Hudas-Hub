-- ─── PROFILES (Save Settings) ───────────────────────────────────────
-- Save the current ON/OFF toggles + all values to a named profile that
-- persists on disk via the executor's file storage. Load applies a saved
-- profile back onto every control (visual + state) in one click.
section("PROFILES")

local PROFILE_DIR = "SH_AutoFarm_Profiles"
local hasFiles = (type(writefile) == "function" and type(readfile) == "function")

local function ensureDir()
    pcall(function()
        if type(makefolder) == "function" and type(isfolder) == "function" and not isfolder(PROFILE_DIR) then
            makefolder(PROFILE_DIR)
        end
    end)
end
local function profilePath(name) return PROFILE_DIR .. "/" .. name .. ".json" end
local function sanitize(name)
    name = tostring(name or ""):gsub("[^%w _%-]", "")
    name = name:gsub("^%s+", ""):gsub("%s+$", "")
    return name
end
local function listProfiles()
    local out = {}
    pcall(function()
        if type(listfiles) == "function" and type(isfolder) == "function" and isfolder(PROFILE_DIR) then
            for _, f in ipairs(listfiles(PROFILE_DIR)) do
                local n = tostring(f):match("([^/\\]+)%.json$")
                if n then out[#out + 1] = n end
            end
        end
    end)
    table.sort(out)
    return out
end
local function saveProfile(name)
    name = sanitize(name)
    if name == "" or not hasFiles then return false end
    ensureDir()
    local data = {}
    for key, c in pairs(controls) do
        local ok, v = pcall(c.get)
        if ok then data[key] = v end
    end
    return (pcall(function() writefile(profilePath(name), HttpService:JSONEncode(data)) end))
end
local function applyProfile(name)
    if not hasFiles then return false end
    local ok, raw = pcall(readfile, profilePath(name))
    if not ok or type(raw) ~= "string" then return false end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or type(data) ~= "table" then return false end
    for key, v in pairs(data) do
        local c = controls[key]
        if c then pcall(c.set, v) end
    end
    return true
end
local function deleteProfile(name)
    pcall(function()
        if type(delfile) == "function" and type(isfile) == "function" and isfile(profilePath(name)) then
            delfile(profilePath(name))
        end
    end)
end

