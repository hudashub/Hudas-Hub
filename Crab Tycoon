-- ===== Feature implementations =====
local function doCollectShells()
    local fired = 0
    for _, d in workspace:GetDescendants() do
        if d.Name == "RollSphere" and not d:GetAttribute("Collected") then
            local tier = d:GetAttribute("Tier") or 1
            local val  = (SHELL_VALUE[tier] or 1) * (d:GetAttribute("Big") and 10 or 1)
                        + (d:GetAttribute("BonusValue") or 0)
            R.CollectShells:FireServer(val)
            d:SetAttribute("Collected", true)
            -- remove the visual so shells don't linger in the water (mirrors CrabController u63)
            local weld = d:FindFirstChildOfClass("WeldConstraint")
            local visual = weld and weld.Part1
            pcall(function() d:Destroy() end)
            if visual and visual.Parent then
                pcall(function()
                    if visual.Parent ~= workspace then visual.Parent:Destroy()
                    else visual:Destroy() end
                end)
            end
            fired += 1
        end
    end
    return fired
end

local function doDepositShells()
    if (get("heldShells") or 0) > 0 then R.DepositShells:FireServer() end
end

local function doCollectCash()
    if (get("pendingCash") or 0) > 0 then R.CollectCash:FireServer() end
end

local function doBuyCrabs()
    local n = crabCounts()
    if n >= MAX_SLOTS then return end
    local cash = get("cash") or 0
    for _, amt in ipairs({100, 25, 5, 1}) do
        if buyAmounts[amt] and cash >= buyCost(amt) then
            R.BuyCrab:FireServer(amt)
            return
        end
    end
end

local function doMergeCrabs()
    local _, byTier = crabCounts()
    for _, c in byTier do
        if c >= 3 then R.MergeCrab:FireServer() return end
    end
end

local function doUpgradeTier()
    local next = (get("buyTier") or 1) + 1
    if next > BUY_TIER_CAP then return end
    local upg = BUY_TIER_UPGRADES[next]
    if not upg then return end
    if (get("crabPower") or 0) >= upg.gate and (get("cash") or 0) >= upg.cost then
        R.UpgradeBuyTier:FireServer()
    end
end

local function doUpgradeAppraisal()
    local lvl  = get("processingLevel") or 1
    local ok, cost = pcall(function() return Formulas.GetProcessingUpgradeCost(lvl) end)
    if ok and cost and (get("cash") or 0) >= cost then
        R.UpgradeProcessing:FireServer()
    end
end

-- ===== Digging anti-lock =====
-- CrabController throttles/stops digging when its internal live-shell counter (u4)
-- reaches ~100 and trips a lock flag (u7). Those only decrement through the game's
-- own collect path, which we bypass when AFK -> the counter climbs and crabs stop
-- digging after a few minutes. We locate that closure and clamp the counter so the
-- crabs keep digging forever. (Indices from the decompiled DescendantAdded handler:
--  7=collect fn, 8=u4 counter, 9=u7 lock.)
local U4_IDX, U7_IDX = 8, 9
local crabHandler
local function findCrabHandler()
    if crabHandler then return crabHandler end
    if not (getconnections and debug and debug.getupvalues and debug.setupvalue) then return nil end
    local ok, conns = pcall(getconnections, workspace.DescendantAdded)
    if not ok then return nil end
    for _, c in conns do
        local f = c.Function
        if f then
            local ok2, ups = pcall(debug.getupvalues, f)
            if ok2 and type(ups[U4_IDX]) == "number"
                    and type(ups[U7_IDX]) == "boolean"
                    and type(ups[7]) == "function" then
                crabHandler = f
                return f
            end
        end
    end
    return nil
end
local function unlockDigging()
    local f = findCrabHandler()
    if not f then return end
    pcall(function()
        if (debug.getupvalue(f, U4_IDX) or 0) > 0 then debug.setupvalue(f, U4_IDX, 0) end
        if debug.getupvalue(f, U7_IDX) then debug.setupvalue(f, U7_IDX, false) end
    end)
end
unlockDigging()  -- clear any lock that's already in effect on load

-- ===== Sifting (sand minigame) automation =====
-- Unlock needs crabPower >= 2000 AND cash >= $1,000,000.
local function doUnlockSifting()
    if get("siftingUnlocked") then return end
    if (get("crabPower") or 0) >= 2000 and (get("cash") or 0) >= 1000000 then
        R.UnlockSifting:FireServer()
    end
end

-- Sand mounds live in SandController's local registry `u1` ({id = {part,pos,amount}}).
-- We read it from the SpawnSand.OnClientEvent handler's upvalues, then fire
-- CollectSand(id) directly (server does not require proximity - verified).
local sandReg
local function findSandRegistry()
    if sandReg then return sandReg end
    if not (getconnections and debug and debug.getupvalues) then return nil end
    local sp = Remotes:FindFirstChild("SpawnSand")
    if not sp then return nil end
    local ok, conns = pcall(getconnections, sp.OnClientEvent)
    if not ok then return nil end
    for _, c in conns do
        local f = c.Function
        if f then
            local ok2, ups = pcall(debug.getupvalues, f)
            if ok2 then
                for _, v in pairs(ups) do
                    if type(v) == "table" then
                        for _, e in pairs(v) do
                            if type(e) == "table" and e.pos ~= nil and e.amount ~= nil then
                                sandReg = v
                                return v
                            end
                        end
                    end
                end
            end
        end
    end
    return nil
end

local function doCollectSand()
    if not get("siftingUnlocked") then return end
    local reg = findSandRegistry()
    if not reg then return end
    local ids = {}
    for id in pairs(reg) do ids[#ids + 1] = id end
    for _, id in ipairs(ids) do
        local e = reg[id]
        if e then
            R.CollectSand:FireServer(id)
            if e.part and e.part.Parent then pcall(function() e.part:Destroy() end) end
            reg[id] = nil
        end
    end
end

local function doSift()
    if not get("siftingUnlocked") then return end
    if (get("heldSand") or 0) > 0 then
        R.RequestSift:FireServer()
    end
end

-- ===== Egg incubator automation (filtered by egg type) =====
-- Flow: collect a ground egg of an ENABLED type (sets heldEggType) -> place it
-- in a free incubator slot -> claim it when the timer is done (gives a crab).
-- Only egg types toggled on in eggFilter ever enter the incubator.
local INC_DUR  = EggConfig.INCUBATE_DURATION or 86400        -- 24h
local QINC_DUR = EggConfig.QUICK_INCUBATE_DURATION or 28800  -- 8h (gamepass)

local function findGroundEggEnabled()
    local bestT, bestPart
    for _, d in workspace:GetDescendants() do
        if d.Name == "EggSphere" then
            local t = d:GetAttribute("EggType")
            if t and eggFilter[t] and (not bestT or t > bestT) then
                bestT, bestPart = t, d  -- prefer the rarest (highest type) enabled egg
            end
        end
    end
    return bestT, bestPart
end

local function doEggIncubator()
    local n = crabCounts()
    local hasQuick = LocalPlayer:GetAttribute("QuickIncubator") and true or false

    -- 1) claim finished incubators (gives a crab; needs a free crab slot)
    local incType = get("incubatingEggType") or 0
    if incType > 0 and (os.time() - (get("incubateStartTime") or 0)) >= INC_DUR then
        if n < MAX_SLOTS then R.ClaimIncubator:FireServer() end
        return
    end
    if hasQuick then
        local qType = get("quickIncEggType") or 0
        if qType > 0 and (os.time() - (get("quickIncStartTime") or 0)) >= QINC_DUR then
            if n < MAX_SLOTS then R.ClaimQuickIncubator:FireServer() end
            return
        end
    end

    -- 2) place an egg into a free slot
    local normalFree = (get("incubatingEggType") or 0) == 0
    local quickFree  = hasQuick and (get("quickIncEggType") or 0) == 0
    if not (normalFree or quickFree) then return end

    local held = get("heldEggType") or 0
    if held > 0 then
        if eggFilter[held] then
            if normalFree then R.IncubateEgg:FireServer()
            elseif quickFree then R.QuickIncubateEgg:FireServer() end
        end
        -- a held egg of a disabled type is left untouched
    else
        local t, part = findGroundEggEnabled()
        if t then
            R.CollectEgg:FireServer(t)
            if part then
                local weld = part:FindFirstChildOfClass("WeldConstraint")
                local vis = weld and weld.Part1
                pcall(function() part:Destroy() end)
                if vis and vis.Parent then pcall(function() vis:Destroy() end) end
            end
        end
    end
end

-- ===== Main loops (separate cadence so collect stays snappy) =====
local lastUnlock = 0
task.spawn(function()  -- fast loop: shells + cash
    while alive() do
        pcall(function()
            if F.collectShells then
                doCollectShells()
                if os.clock() - lastUnlock > 1.5 then  -- keep crabs digging
                    unlockDigging()
                    lastUnlock = os.clock()
                end
            end
            if F.depositShells then doDepositShells() end
            if F.collectCash   then doCollectCash()   end
            if F.collectSand   then doCollectSand()   end
        end)
        task.wait(0.25)
    end
end)

task.spawn(function()  -- slow loop: spending (buy/merge/upgrade)
    while alive() do
        pcall(function()
            if F.mergeCrabs  then doMergeCrabs()      end
            if F.upgradeTier then doUpgradeTier()     end
            if F.upgradeAppr then doUpgradeAppraisal()end
            if F.buyCrabs    then doBuyCrabs()         end
            if F.unlockSift  then doUnlockSifting()    end
            if F.autoSift    then doSift()             end
            if F.eggIncubator then doEggIncubator()    end
        end)
        task.wait(0.6)
    end
end)

