-- Dynamic Plot Sales (NPC) Tracker
local lastSales = player:GetAttribute("LifetimeNPCSales") or 0
local lastCash = player:GetAttribute("Cash") or 0
local isNPCSelling = false
local scriptStart = os.clock()

track(player:GetAttributeChangedSignal("LifetimeNPCSales"):Connect(function()
    local newSales = player:GetAttribute("LifetimeNPCSales") or 0
    if newSales <= lastSales then return end -- only positive changes
    
    isNPCSelling = true
    
    -- If it's during script startup cooldown, just update baseline and return
    if os.clock() - scriptStart < 1.5 then
        lastSales = newSales
        lastCash = player:GetAttribute("Cash") or 0
        isNPCSelling = false
        return
    end
    
    -- Use task.spawn to handle async cash-wait without coroutine.yield
    task.spawn(function()
        local currentCash = player:GetAttribute("Cash") or 0
        if currentCash == lastCash then
            -- Cash has not replicated yet, poll briefly instead of yield
            local waitStart = os.clock()
            while os.clock() - waitStart < 1.5 do
                task.wait(0.1)
                currentCash = player:GetAttribute("Cash") or 0
                if currentCash ~= lastCash then break end
            end
            currentCash = player:GetAttribute("Cash") or 0
        end
        
        local diffSales = newSales - lastSales
        local diffCash = currentCash - lastCash
        
        if diffSales > 0 then
            rebuildPlacedItemsCache()
            local plot = State.myPlot or findMyPlot()
            local currentGuids = {}
            if plot then
                for _, v in ipairs(plot:GetDescendants()) do
                    local guid = v:GetAttribute("GUID")
                    if guid then currentGuids[guid] = true end
                end
            end
            
            local soldBaseValue = 0
            local soldCount = 0
            for guid, basePrice in pairs(PlacedItems) do
                if not currentGuids[guid] then
                    soldBaseValue = soldBaseValue + basePrice
                    PlacedItems[guid] = nil
                    soldCount = soldCount + 1
                    if soldCount >= diffSales then break end
                end
            end
            
            if soldCount < diffSales then
                local missing = diffSales - soldCount
                local avgDiff = diffCash / diffSales
                soldBaseValue = soldBaseValue + (avgDiff * 0.77) * missing
            end
            
            local profit = diffCash - soldBaseValue
            if diffCash > 0 then
                State.earnings = State.earnings + profit
                State.itemsSold = State.itemsSold + diffSales
            else
                State.itemsSold = State.itemsSold + diffSales
            end
        end
        
        lastSales = newSales
        lastCash = currentCash
        isNPCSelling = false
    end)
end))

track(player:GetAttributeChangedSignal("Cash"):Connect(function()
    local val = player:GetAttribute("Cash") or 0
    task.wait(0.05)
    if not isNPCSelling then
        lastCash = val
    end
end))

-- Pawn Shop Rate Listener
local function formatPawnRateText(rate)
    local relRate = math.floor((rate - 1) * 100 + 0.5)
    local sign = relRate >= 0 and "+" or ""
    return sign .. tostring(relRate) .. "%"
end

local function updateQuickSellRate(rate)
    if quickSellRateLabel then
        quickSellRateLabel.Text = formatPawnRateText(rate)
    end
end

task.spawn(function()
    pcall(function()
        local state = R.GetPawnState:InvokeServer()
        if state and state.rate then
            currentPawnRate = state.rate
            updateQuickSellRate(state.rate)
        end
    end)
end)

track(R.RateChanged.OnClientEvent:Connect(function(data)
    if data and data.rate then
        currentPawnRate = data.rate
        updateQuickSellRate(data.rate)
    end
end))

