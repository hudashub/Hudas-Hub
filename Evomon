    -- exclusive segmented control (replaces the old chips)
    local function makeSegment(parent, order, stateTbl, items)
        local seg = Instance.new("Frame")
        seg.Size = UDim2.new(1, 0, 0, 32); seg.BackgroundColor3 = COL.field
        seg.LayoutOrder = order or 0; seg.Parent = parent
        corner(seg, 8); softStroke(seg, 0.93)
        pad(seg, 3, 3, 3, 3)
