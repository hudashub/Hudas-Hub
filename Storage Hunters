    end
    local profs = listProfiles()
    if #profs == 0 then
        local empty = Instance.new("Frame",listHolder)
        empty.Size = UDim2.new(1,0,0,24); empty.BackgroundTransparency = 1; empty.LayoutOrder = 1
        mkLabel(empty, hasFiles and "No saved profiles yet" or "Executor has no file access",
            UDim2.new(1,0,1,0),UDim2.new(0,0,0,0),11,nil,Color3.fromRGB(120,120,140),1,Enum.TextXAlignment.Center)
        return
    end
    for i, name in ipairs(profs) do
        local r = Instance.new("Frame",listHolder)
        r.Size = UDim2.new(1,0,0,30); r.BackgroundColor3 = Color3.fromRGB(14,14,14)
