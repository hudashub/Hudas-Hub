        ddl.Visible = false; ddl.LayoutOrder = 3; ddl.Parent = wrap
        corner(ddl, 8); softStroke(ddl, 0.92)
        pad(ddl, 4, 4, 4, 4)
        vlist(ddl, 2)
        local function close() ddl.Visible = false; chev.Text = "v" end
        table.insert(openDDs, close)
