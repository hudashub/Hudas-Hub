local function getClosestContainer()
    local debris = WS:FindFirstChild("_Debris")
    local garages = debris and debris:FindFirstChild("Garages")
    if not garages or not rootPart then return nil end
    
    local best = nil
    local maxEntryCost = -1
    local minDist = math.huge
    local myPos = rootPart.Position
    
    for _, g in ipairs(garages:GetChildren()) do
        if State.SelectedContainers[g.Name] then
            local prompt = g:FindFirstChild("EnterAuction", true)
            if prompt and prompt:IsA("ProximityPrompt") and prompt.Enabled then
                local promptPart = prompt.Parent
                if promptPart and promptPart:IsA("BasePart") then
                    local d = (promptPart.Position - myPos).Magnitude
                    local entryCost = g:GetAttribute("EntryCost") or 0
                    
                    if entryCost > maxEntryCost then
                        maxEntryCost = entryCost
                        minDist = d
                        best = { model = g, prompt = prompt, part = promptPart }
                    elseif entryCost == maxEntryCost then
                        if d < minDist then
                            minDist = d
                            best = { model = g, prompt = prompt, part = promptPart }
                        end
                    end
                end
            end
        end
    end
    return best
end

