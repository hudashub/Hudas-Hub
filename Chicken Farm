-- responsive
local DESIGN_W, DESIGN_H = 500, 560
local camera = workspace.CurrentCamera
local fab
local uiScale = Instance.new("UIScale"); uiScale.Parent = main
local function responsiveHeight()
    local vp = camera and camera.ViewportSize
    if not vp or vp.Y < 1 then return DESIGN_H end
    local s = uiScale.Scale > 0 and uiScale.Scale or 1
    return math.min(DESIGN_H, (vp.Y * 0.9) / s)
end
local function applyResponsive()
    local vp = camera and camera.ViewportSize
    if not vp or vp.X < 1 or vp.Y < 1 then return end
    local scale = math.clamp(math.min(vp.X/1366, vp.Y/768), 0.5, 1.2)
    uiScale.Scale = scale
    main.Size = UDim2.fromOffset(DESIGN_W, responsiveHeight())
    local pxW, pxH = DESIGN_W*scale, responsiveHeight()*scale
    if main.AbsoluteSize.X > 0 then
        local ap = main.AbsolutePosition
        main.Position = UDim2.fromOffset(
            math.clamp(ap.X, 0, math.max(0, vp.X - pxW)),
            math.clamp(ap.Y, 0, math.max(0, vp.Y - pxH)))
    end
    if fab then
        local fs = math.floor(54*scale)
        fab.Size = UDim2.fromOffset(fs, fs)
        if fab.AbsoluteSize.X > 0 then
            local fp = fab.AbsolutePosition
            fab.Position = UDim2.fromOffset(
                math.clamp(fp.X, 0, math.max(0, vp.X - fs)),
                math.clamp(fp.Y, 0, math.max(0, vp.Y - fs)))
        end
    end
end

