                ob.TextSize = 12; ob.TextXAlignment = Enum.TextXAlignment.Left
                ob.TextTruncate = Enum.TextTruncate.AtEnd; ob.LayoutOrder = i; ob.Parent = ddl
                corner(ob, 6)
