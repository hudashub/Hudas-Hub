-- ============================================================
--  AUTO-CATCH RARE  (shiny / prismatic only)
--  When the post-battle catch window opens and the target is shiny or colorful
--  (prismatic), select the chosen ball via the game's own ball-cycle handler and
--  throw it with handleCatchButtonClick — i.e. exactly what a real player does,
--  so server-side validation is satisfied. Shiny/colorful is known client-side
--  ONLY at this point (catch phase), which is why this is possible.
-- ============================================================
local CatchCtrl
pcall(function() CatchCtrl = require(ReplicatedStorage.Controller.BattleCatchPetWindowController) end)
-- per-species pity reader (the same data the catch screen's Obtain Rate panel
-- shows). getPityInfo = SHINY pity (x/600), getColorPityInfo = PRISMATIC/sparkle
-- pity (x/150). Both keyed by the PET configId.
local ShinyLottery
pcall(function() ShinyLottery = require(ReplicatedStorage.Script.ShinyPetLottery.ShinyPetLotteryService) end)
local function pityInfo(cfgId)
    local sc, sm, pc, pm
    if ShinyLottery and cfgId then
        pcall(function()
            local ec, d = ShinyLottery.getPityInfo(cfgId)
            if ec == 20000 and type(d) == "table" then sc, sm = d.current, d.pity end
        end)
        pcall(function()
            local ec, d = ShinyLottery.getColorPityInfo(cfgId)
            if ec == 20000 and type(d) == "table" then pc, pm = d.current, d.pity end
        end)
    end
    return sc, sm, pc, pm
end
-- the game's own guarantee rule (BattleCatchPetWindowController): the NEXT catch
-- is 100% prismatic when pity <= current + 1. That's the "parked" state — stop
-- catching normals so the guaranteed prismatic stays reserved for a shiny.
-- NOTE: only base-form species with a shiny variant HAVE pity (getPityInfo
-- returns ec 20002 for the rest — evolved forms, Mirefish, Flutterby, …).
local function prismPityState(cfgId)
    local _, _, pc, pm = pityInfo(cfgId)
    local hasPity = type(pc) == "number" and type(pm) == "number" and pm > 0
    return hasPity, hasPity and (pc + 1 >= pm)
end
-- throw a specific ball: select it via the game's own ball-cycle, then click catch
local function throwBall(ballId)
    local CW = CatchCtrl
    if not CW or not ballId then return end
    if typeof(CW.getSelectedBallItemId) == "function" and typeof(CW.triggerSelectNextBall) == "function" then
        for _ = 1, 12 do
            if CW.getSelectedBallItemId() == ballId then break end
            pcall(CW.triggerSelectNextBall)
            task.wait(0.08)
        end
    end
    if typeof(CW.handleCatchButtonClick) == "function" then pcall(CW.handleCatchButtonClick) end
end
-- flip the Auto Catch master toggle off (used by Stop after Shiny: King &
-- Prismatic balls are 100% catch rate, one throw = guaranteed — you only need
-- one evomon of that mutation, don't keep spending expensive balls).
local function stopAutoCatch()
    F.autoCatch = false
    if controls.autoCatch and controls.autoCatch.set then pcall(controls.autoCatch.set, false) end
end
-- leave the catch (give up) — direct GIVE_UP_CATCH operate, bypasses the UI confirm
local function giveUpCatch()
    local mb = getCtrl("MainBattleWindowController")
    if mb and typeof(mb.applyGiveUpCatch) == "function" then
        pcall(function() mb.applyGiveUpCatch() end)
    elseif ReqOperateBattle then
        pcall(function() ReqOperateBattle:InvokeServer({ actionType = 8 }) end)
    end
end
-- catch-window watcher. Detectable at the catch screen: SHINY + PRISMATIC only
-- (talent is server-rolled on catch, never shown). The target is sorted into a
-- category (shinyPrism / shiny / prism / normal) and the ball from that
-- category's dropdown is thrown, retrying up to maxCatchCount then leaving.
-- Shiny+Prismatic Farm (F.spFarm) takes priority over Auto Catch: build ball on
-- normals until the species' prismatic pity parks at max-1, then leave normals
-- and secure any shiny with the catch ball (= guaranteed shiny+prismatic).
-- Ball "Skip (leave)" (id 0) -> give up the catch immediately.
-- Stop after Shiny: a 100%-rate throw (King/Prism ball) on a shiny auto-offs
-- Auto Catch so expensive balls aren't spent on duplicates.
-- With Auto Catch OFF but Auto-Farm ON: leave common/prismatic to keep
-- grinding, PAUSE on shiny so it's never lost.
-- Retry: each catch has maxCatchCount attempts. We throw, the submit locks during the
-- throw, and on a miss it unlocks for the next attempt — so throw again while throws <
-- maxCatchCount. A 1.5s throttle guards the brief pre-lock gap; getRemainingCatchCount is
-- unreliable here so we count our own throws against catchPetInfo.maxCatchCount.
task.spawn(function()
    local lastAct, throws, windowSince = 0, 0, nil
    while alive() do
        if (F.autoCatch or F.autoFarm or F.spFarm) and CatchCtrl and typeof(CatchCtrl.getWindow) == "function" then
            local win
            pcall(function() win = CatchCtrl.getWindow() end)
            if type(win) == "table" and type(win.data) == "table" then
                if not windowSince then windowSince = os.clock() end
                local cpi = win.data.catchPetInfo
                local visible = win.MainCanvasGroup == nil or win.MainCanvasGroup.Visible == true
                local locked = (typeof(CatchCtrl.isCatchSubmitLocked) == "function") and CatchCtrl.isCatchSubmitLocked() or false
                local maxC = (type(cpi) == "table" and tonumber(cpi.maxCatchCount)) or 2
                -- only decide once the catch data is loaded AND the window has settled,
                -- so the shiny/colorful flags are populated (acting too early misread a
                -- prismatic as common and threw a Common ball at it).
                local dataReady = type(cpi) == "table"
                local settled = (os.clock() - windowSince) > 1.0
                if visible and not locked and dataReady and settled and (os.clock() - lastAct) > 1.5 then
                    -- robust shiny/prismatic detection (flag, else derive from catch info)
                    local shiny = win.data.isCatchPetShiny == true
                    local prism = win.data.isCatchPetColorful == true
                    if not prism and type(cpi.colorId) == "number" and cpi.colorId > 0
                       and type(cpi.patternId) == "number" and cpi.patternId > 0 then prism = true end
                    if not shiny and cpi.configId and CM then
                        local pc = CM.getConfig(CN.PET, cpi.configId)
                        if type(pc) == "table" and pc.shinyTypeId == 2 then shiny = true end
                    end
                    local category = (shiny and prism and "shinyPrism") or (shiny and "shiny")
                                     or (prism and "prism") or "normal"
                    if F.spFarm then
                        -- SHINY+PRISMATIC FARM (takes priority over Auto Catch):
                        --   shiny            -> catch ball (on a parked pity = shiny+prismatic)
                        --   prismatic-only   -> leave (never spend the reserved pity on a non-shiny)
                        --   normal, parked   -> leave (defeat builds shiny pity, prismatic stays reserved)
                        --   normal, building -> build ball (catch = prismatic pity +1)
                        if shiny then
                            if throws < maxC then
                                throwBall(spCatchBall); throws = throws + 1; lastAct = os.clock()
                                if F.stopAfterShiny and (spCatchBall == 2000017 or spCatchBall == 2000018) then
                                    F.spFarm = false
                                    if controls.spFarm and controls.spFarm.set then pcall(controls.spFarm.set, false) end
                                end
                            end
                        elseif prism then
                            giveUpCatch(); lastAct = os.clock()
                        else
                            local hasPity, parked = prismPityState(cpi.configId)
                            if not hasPity or parked then
                                -- no pity to build (species has none) or parked -> defeat only
                                giveUpCatch(); lastAct = os.clock()
                            elseif throws < maxC then
                                throwBall(spBuildBall); throws = throws + 1; lastAct = os.clock()
                            else
                                giveUpCatch(); lastAct = os.clock()
                            end
                        end
                    elseif F.autoCatch then
                        local ball = catchBall[category] or 0
                        if ball == 0 then
                            giveUpCatch(); lastAct = os.clock()               -- Skip (leave)
                        elseif throws < maxC then
                            throwBall(ball); throws = throws + 1; lastAct = os.clock()
                            if shiny and F.stopAfterShiny and (ball == 2000017 or ball == 2000018) then
                                stopAutoCatch()                               -- 100% ball -> caught, stop spending
                            end
                        else
                            giveUpCatch(); lastAct = os.clock()               -- all attempts missed -> leave
                        end
                    elseif F.autoFarm then
                        -- farm-only: leave common/prismatic so the grind continues; pause on shiny
                        if not shiny then giveUpCatch(); lastAct = os.clock() end
                    end
                end
            else
                lastAct, throws, windowSince = 0, 0, nil   -- catch window closed -> arm for the next one
            end
        else
            lastAct, throws, windowSince = 0, 0, nil
        end
        task.wait(0.4)
    end
end)

-- Reconcile inBattle: if a ResSettleBattle is ever missed, inBattle could stay true
-- and freeze the farm after one fight. If there's no live battle cache AND no catch
-- window, we're not in a battle — clear the flag so the farm resumes.
