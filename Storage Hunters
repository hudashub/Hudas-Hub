function hasPendingPriorities()
    local ok, inv = pcall(function() return R.GetPlayerInv:InvokeServer() end)
    if not ok or type(inv) ~= "table" then return false end
    
    -- Check Auto Favorite Safe
    if State.AutoFavoriteSafe then
        for guid, entry in pairs(inv) do
            if entry.Favorited ~= true then
                local id = tostring(entry.ItemId or "")
                local itemData = Items and Items[id]
                if itemData and itemData.SafeId and State.SelectedFavoriteSafes[itemData.Name] then
                    return true
                end
            end
        end
    end
    
    -- Check Auto Favorite Gavel Trophy
    if State.AutoGavelFavorite then
        for guid, entry in pairs(inv) do
            if entry.Favorited ~= true and isGavelTrophy(entry) and matchesGavelTrophyFilters(entry) then
                return true
            end
        end
    end
    
    -- Check Auto Favorite Accessories
    if State.AutoAccessoryFavorite then
        for guid, entry in pairs(inv) do
            if entry.Favorited ~= true and isAccessory(entry) and matchesAccessoryFilters(entry) then
                return true
            end
        end
    end
    
    -- Check Auto Favorite Items
    if State.AutoFavorite then
        for guid, entry in pairs(inv) do
            if entry.Favorited ~= true then
                local id = tostring(entry.ItemId or "")
                local price = getInventoryItemPrice(id, entry)
                if price >= (State.AutoFavoritePrice or 50000) then
                    return true
                end
            end
        end
    end
    
    -- Check Auto Lockpick Safe
    if State.AutoLockpickSafe then
        for guid, entry in pairs(inv) do
            if entry.Favorited ~= true then
                local id = tostring(entry.ItemId or "")
                local itemData = Items and Items[id]
                if itemData and itemData.SafeId and State.SelectedSafes[itemData.Name] then
                    return true
                end
            end
        end
    end
    
    return false
end

