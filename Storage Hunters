local function findNPCInArea(areaName)
    local areas = WS:FindFirstChild("Areas")
    local folder = areas and areas:FindFirstChild(areaName)
    if folder then
        for _, desc in ipairs(folder:GetDescendants()) do
            if desc:IsA("Humanoid") and desc.Parent:IsA("Model") and desc.Parent ~= player.Character then
                return desc.Parent
            end
        end
    end
    return nil
end

local function getAreaCenter(areaName)
    local areas = WS:FindFirstChild("Areas")
    local folder = areas and areas:FindFirstChild(areaName)
    if not folder then return nil end
    
    local boundary = folder:FindFirstChild("AreaBoundary")
    if boundary and boundary:IsA("BasePart") then
        return boundary.Position
    end
    
    local totalPos = Vector3.new(0,0,0)
    local count = 0
    for _, desc in ipairs(folder:GetDescendants()) do
        if desc:IsA("BasePart") then
            totalPos = totalPos + desc.Position
            count = count + 1
        end
    end
    if count > 0 then
        return totalPos / count
    end
    return nil
end

local function getClosestGarageTo(position)
    local debris = WS:FindFirstChild("_Debris")
    local garages = debris and debris:FindFirstChild("Garages")
    if not garages then return nil end
    
    local closest = nil
    local minDist = math.huge
    for _, g in ipairs(garages:GetChildren()) do
        local pos = g:GetPivot().Position
        local dist = (pos - position).Magnitude
        if dist < minDist then
            minDist = dist
            closest = g
        end
    end
    return closest
end

