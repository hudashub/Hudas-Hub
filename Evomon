-- crit-boost skill detector: a skill counts if it (or its main effect) grants any
-- known crit buff id. Cached per-skillId. Verified Store Power / Critical Focus /
-- Steel Smash / Blaze Storm resolve true.
local CRIT_BUFFS = {[4000025]=true,[4000026]=true,[4017009]=true,[4017010]=true,[4017011]=true,[15024]=true,[4002016]=true,[4002017]=true,[4002018]=true}
local critSkillCache = {}
local function deepHasCritBuff(t, depth)
    if depth > 4 or type(t) ~= "table" then return false end
    for _, v in pairs(t) do
        if type(v) == "number" and CRIT_BUFFS[v] then return true end
        if type(v) == "table" and deepHasCritBuff(v, depth + 1) then return true end
    end
    return false
end
local function isCritSkill(skillId)
    if not skillId then return false end
    if critSkillCache[skillId] ~= nil then return critSkillCache[skillId] end
    local hit = false
    pcall(function()
        local cfg = CM and CM.getConfig(CN.SKILL, skillId)
        if type(cfg) == "table" then
            if deepHasCritBuff(cfg, 0) then hit = true end
            if not hit and cfg.mainEffect then
                local eff = CM.getConfig(CN.SKILL_EFFECT, cfg.mainEffect)
                if deepHasCritBuff(eff, 0) then hit = true end
            end
        end
    end)
    critSkillCache[skillId] = hit
    return hit
end

