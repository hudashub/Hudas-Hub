                                        pcall(function() desc:Activate() end)
                                        if getconnections then
                                            pcall(function()
                                                for _, conn in ipairs(getconnections(desc.MouseButton1Click)) do
                                                    conn:Fire()
                                                end
                                            end)
                                            pcall(function()
                                                for _, conn in ipairs(getconnections(desc.Activated)) do
                                                    conn:Fire()
                                                end
                                            end)
                                        end
                                        task.wait(0.2)
                                    end
                                end
                            end
                        end
                    end
                end
            end)
            task.wait(0.5)
        end
    end)
    trackThread(autoPromptThread)
end

