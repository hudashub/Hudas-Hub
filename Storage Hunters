local bidConn, auctionOpenConn
local function startAutoBid()
    if bidConn then bidConn:Disconnect() end
    if auctionOpenConn then auctionOpenConn:Disconnect() end

    -- Hook UpdateCurrentWinningBid — outbid whoever is winning
    bidConn = R.UpdateWinBid.OnClientEvent:Connect(function(currentBid, winnerName, bidderChar, nextBidPrice, garageModel)
        if not State.inAuction then return end

        if not State.AutoBidWin then return end
        if winnerName == player.Name then return end -- already winning

        -- Price filter: only join auctions whose CURRENT bid is at/above the threshold
        local curr = tonumber(currentBid) or 0
        if State.AutoBidFilterPrice and curr < State.AutoBidMinValue then
            State.status = "💲 Skip: bid $" .. fmt(curr) .. " < min $" .. fmt(State.AutoBidMinValue)
            task.spawn(function()
                pcall(function() R.LeaveAuction:InvokeServer() end)
            end)
            return
        end

        local nextBid = (tonumber(nextBidPrice) or curr + 1)
        if nextBid <= State.MaxBid then
            task.delay(State.BidDelay, function()
                if State.AutoBidWin and State.inAuction then
                    pcall(function() R.BidRemote:FireServer(nextBid) end)
                    State.currentBid = nextBid
                    State.status = "🔨 Bid: $" .. fmt(nextBid)
                end
            end)
        else
            State.status = "⚠️ Max bid $" .. fmt(State.MaxBid) .. " reached"
        end
    end)

    -- Hook ToggleBiddingUI — know when auction starts/ends
    auctionOpenConn = R.ToggleBiddingUI.OnClientEvent:Connect(function(open)
        State.inAuction = open
        if open then
            State.currentBid = 0
            State.status = "🏪 Auction open — bidding!"
            if State.AutoBidWin and not State.AutoBidFilterPrice then
                task.delay(0.6, function()
                    if State.inAuction and State.AutoBidWin then
                        pcall(function() R.BidRemote:FireServer(1) end)
                    end
                end)
            end
        else
            if State.currentBid > 0 then
                State.bidsWon = State.bidsWon + 1
                State.status = "🏆 Won! (" .. State.bidsWon .. " total)"
            else
                State.status = "Auction ended"
            end
            State.currentBid = 0
            State.currentGarage = nil
        end
    end)
    track(bidConn); track(auctionOpenConn)
end

-- ─── AUTO START AUCTION (step on a pad → start it) ────────────────────
-- Fires the "Start Auction" ProximityPrompt (named EnterAuction) the moment you
-- walk onto an auction pad, so auctions begin hands-free.
local startAuctionThread, startAuctionConn, startAuctionUIConn
local startAuctionCooldown = 0
local auctionUIOpen = false

local function tryStartAuction(prompt)
    if not State.AutoStartAuction or auctionUIOpen then return end
    if not prompt or prompt.Name ~= "EnterAuction" or not prompt.Enabled then return end
    if os.clock() < startAuctionCooldown then return end
    local part = prompt.Parent
    if part and part:IsA("BasePart") and rootPart
        and (part.Position - rootPart.Position).Magnitude > prompt.MaxActivationDistance then
        return   -- only when you're actually standing on the pad
    end
    startAuctionCooldown = os.clock() + 3
    pcall(function() fireproximityprompt(prompt) end)
    State.status = "🏁 Auto-started auction"
end

local function startAutoStartAuction()
    if startAuctionThread then pcall(task.cancel, startAuctionThread) end
    if startAuctionConn then startAuctionConn:Disconnect() end
    if startAuctionUIConn then startAuctionUIConn:Disconnect() end
    auctionUIOpen = false
    -- know when a bidding UI is open so we don't restart mid-auction
    startAuctionUIConn = R.ToggleBiddingUI.OnClientEvent:Connect(function(open) auctionUIOpen = open end)
    -- instant: the prompt shows the moment you step onto a pad
    startAuctionConn = PPS.PromptShown:Connect(function(prompt) tryStartAuction(prompt) end)
    -- backup sweep of the auction pads
    startAuctionThread = task.spawn(function()
        while State.AutoStartAuction do
            if not auctionUIOpen and rootPart then
                local debris  = WS:FindFirstChild("_Debris")
                local garages = debris and debris:FindFirstChild("Garages")
                if garages then
                    for _, g in ipairs(garages:GetChildren()) do
                        if not State.AutoStartAuction then break end
                        local prompt = g:FindFirstChild("EnterAuction", true)
                        if prompt and prompt:IsA("ProximityPrompt") then tryStartAuction(prompt) end
                    end
                end
            end
            task.wait(0.5)
        end
    end)
    track(startAuctionConn); track(startAuctionUIConn); trackThread(startAuctionThread)
end

-- ─── AUTO SELL FROM INVENTORY ─────────────────────────────────────────
-- Items in the player's dragging inventory are tracked server-side.
-- We use GetDraggingInventory → SellItem(guid) for each one.
-- Also scan the plot for placed items and sell those too.

local function sellFromDraggingInventory()
    local ok, inv = pcall(function()
        return PlotFolder:WaitForChild("GetDraggingInventory"):InvokeServer()
    end)
    if ok and type(inv) == "table" then
        local count = 0
        for guid, itemData in pairs(inv) do
            if not State.AutoSellInv then break end
            pcall(function() R.SellItemRemote:FireServer(guid) end)
            local price = 0
            if type(itemData) == "table" then
                price = tonumber(itemData.StockPrice or itemData.Price or 0) or 0
            end
            State.itemsSold = State.itemsSold + 1
            local baseVal = shelfPrice(tostring(itemData.ItemId), itemData)
            local profit = baseVal * (currentPawnRate - 1)
            State.earnings = State.earnings + profit
            count = count + 1
            task.wait(State.SellDelay)
        end
        return count
    end
    return 0
end

local function sellFromPlot()
    local plot = State.myPlot or findMyPlot()
    if not plot then return 0 end
    State.myPlot = plot
    local count = 0
    for _, v in ipairs(plot:GetDescendants()) do
        if not State.AutoSellInv then break end
        local guid = v:GetAttribute("GUID")
        -- Only sell items (not furniture/building parts)
        local cat = v:GetAttribute("Category")
        local isFurniture = cat == "Furniture" or cat == "Walls" or cat == "Roofs" or cat == "Floors"
        if guid and not isFurniture then
            local price = tonumber(v:GetAttribute("StockPrice")) or 0
            pcall(function() R.SellItemRemote:FireServer(guid) end)
            State.itemsSold = State.itemsSold + 1
            local profit = price * (currentPawnRate - 1)
            State.earnings = State.earnings + profit
            count = count + 1
            task.wait(State.SellDelay)
        end
    end
    return count
end

local function sellAll()
    State.status = "💵 Selling inventory..."
    local c1 = sellFromDraggingInventory()
    local c2 = sellFromPlot()
    local total = c1 + c2
    if total > 0 then
        State.status = "✅ Sold " .. total .. " items | Total: $" .. fmt(State.earnings)
    else
        State.status = "📭 Nothing to sell"
    end
end

local sellThread
local function startAutoSell()
    if sellThread then pcall(task.cancel, sellThread) end
    sellThread = task.spawn(function()
        while State.AutoSellInv do
            if hasPendingPriorities() then
                State.status = "⏳ Waiting for inventory priorities..."
                task.wait(1)
                continue
            end
            sellAll()
            task.wait(4)
        end
    end)
    trackThread(sellThread)
end

-- ─── AUTO UNLOAD (vehicle → inventory when there's space) ──────────────
-- Uses server remotes, so it works even when you are NOT in the vehicle and far
-- from base. Unloads only while the inventory has free slots; if full it leaves
-- the cargo in the vehicle (won't force-unload).
local VehEvents     = Events:WaitForChild("Vehicles")
R.GetVehItems   = VehEvents:WaitForChild("GetVehicleItems")
R.TransferToInv = VehEvents:WaitForChild("TransferVehicleItemsToInventory")
R.GetOwnedVehicles = VehEvents:WaitForChild("GetOwnedVehicles")
R.RequestSpawn = VehEvents:WaitForChild("RequestSpawn")
local UnloadItems   -- Items DB, for reading weights (heaviest-first option)
pcall(function() UnloadItems = require(RS.Modules.Items) end)

local function freeInvSpace()
    local cap = player:GetAttribute("InventoryCap") or 0
    local cnt = player:GetAttribute("InventoryCount") or 0
    return math.max(0, cap - cnt)
end

local function myVehicles()
    local out = {}
    for _, m in ipairs(WS:GetChildren()) do
        if m:GetAttribute("VehicleGUID") and m:GetAttribute("OwnerUserId") == player.UserId then
            table.insert(out, m)
        end
    end
    return out
end

local function doUnloadPass()
    local free = freeInvSpace()
    if free <= 0 then
        State.status = "📦 Inventory full — holding cargo"
        return 0
    end
    local moved = 0
    for _, veh in ipairs(myVehicles()) do
        if free <= 0 then break end
        local vguid = veh:GetAttribute("VehicleGUID")
        local ok, items = pcall(function() return R.GetVehItems:InvokeServer(vguid) end)
        if ok and type(items) == "table" then
            -- order the cargo; with Heaviest-First on, move the heaviest items first
            local list = {}
            for g, entry in pairs(items) do
                local data = UnloadItems and UnloadItems[tostring(entry.ItemId)]
                list[#list + 1] = { guid = g, weight = (data and data.Weight) or 0 }
            end
            if State.PrioritizeHeavy then
                table.sort(list, function(a, b) return a.weight > b.weight end)
            end
            local guids = {}
            for _, e in ipairs(list) do
                guids[#guids + 1] = e.guid
                if #guids >= free then break end   -- only take what fits
            end
            if #guids > 0 then
                pcall(function() R.TransferToInv:FireServer(guids) end)
                moved = moved + #guids
                free  = free - #guids
            end
        end
    end
    if moved > 0 then State.status = "📦 Unloaded " .. moved .. " item(s)" end
    return moved
end

local unloadThread
local function startAutoUnload()
    if unloadThread then pcall(task.cancel, unloadThread) end
    unloadThread = task.spawn(function()
        while State.AutoUnload do
            doUnloadPass()
            task.wait(State.UnloadScanDelay)
        end
    end)
    trackThread(unloadThread)
end

-- ─── AUTO PICKUP (walk near → auto-collect) ─────────────────────────────
-- Items live in Workspace._Carryables. Each is a Model with a Base part holding a
-- ProximityPrompt: "PickupPrompt" (loose item, "Add to Vehicle") or "OpenBoxPrompt"
-- (a box you open, which then drops a loose item picked up on the next pass).
--
-- Two hard rules learned from the live game:
--   1) Pickup is server-authoritative — the server checks your REAL character
--      position, so we can't grab from afar and we never teleport. We just auto-press
--      the prompt while YOU walk near it (you must be grounded + within range).
--   2) Every carryable has an "Owner" attribute (UserId of who won it). You can only
--      collect your OWN items, so we skip everyone else's.
--
-- Primary path: hook ProximityPromptService.PromptShown — the game shows the prompt
-- exactly when you're in range, so firing it the moment it appears = instant collect.
-- Backup path: a light loop fires any owned prompt already within MaxActivationDistance.

-- Each carryable Model has an "Owner" attribute = the UserId of whoever won it.
-- You can ONLY collect your own items, so we skip everyone else's.
local myUserId = player.UserId

-- Carryables use two prompt types we care about:
--   "PickupPrompt"  -> loose item, "Add to Vehicle"
--   "OpenBoxPrompt" -> a box/crate you open (reveals a loose item, picked next pass)
-- We fire ONLY these (never "Start Auction" / "Lost & Found" etc.).
local GRAB_PROMPTS = { PickupPrompt = true, OpenBoxPrompt = true }

local function carryableModelOf(prompt)
    -- Prompt -> Base -> ItemModel
    local base = prompt.Parent
    local model = base and base.Parent
    return model
end

local function isMine(model)
    if not model then return false end
    local owner = model:GetAttribute("Owner")
    -- nil / 0 = free/unowned item; otherwise must match our UserId
    return owner == nil or owner == 0 or owner == myUserId
end

-- ─── PICKUP FILTERS (price / rarity / mutation) ───────────────────────────
-- Resolve an item model's real value, rarity and mutations the same way the game does:
--   Items[ItemId]   -> BasePrice + Rarity
--   MutatorModule:CalculatePriceForEntry(BasePrice, entry)  -> live value (w/ mutators+condition)

resolveItemInfo = function(model)
    if not model or not Items or not MutatorMod then return nil end
    local ok, entry = pcall(function() return MutatorMod:BuildEntryFromAttributes(model) end)
    if not ok or type(entry) ~= "table" then return nil end
    local id     = tostring(entry.ItemId or model:GetAttribute("ItemId") or "")
    local data   = Items[id]
    local rarity = (data and data.Rarity) or "Uncommon"
    local price  = 0
    pcall(function() price = MutatorMod:CalculatePriceForEntry((data and data.BasePrice) or 0, entry) or 0 end)
    if Grading and entry.Grade and Grading.GradeMultipliers and Grading.GradeMultipliers[entry.Grade] then
        price = price * Grading.GradeMultipliers[entry.Grade]
    end
    -- collect mutation names present on the item
    local mutations = {}
    if type(entry.Mutators) == "table" then
        for _, m in ipairs(entry.Mutators) do
            local n = (type(m) == "table") and (m.name or m.Name) or tostring(m)
            if n then mutations[n] = true end
        end
    end
    pcall(function()
        local sz = MutatorMod:GetSizeMutator(entry)
        if sz then local n = sz.name or sz.Name; if n then mutations[n] = true end end
    end)
    return { price = price, rarity = rarity, mutations = mutations }
end

-- Returns true if the item passes every ENABLED filter (price/rarity/mutation).
-- If the item info can't be resolved, fail open (don't block the pickup).
local function passesFilters(model)
    if not (State.FilterPrice or State.FilterRarity or State.FilterMutation) then return true end
    local info = resolveItemInfo(model)
    if not info then return true end
    if State.FilterPrice and (info.price or 0) < State.MinPrice then return false end
    if State.FilterRarity and not State.RarityAllow[info.rarity] then return false end
    if State.FilterMutation then
        local pass = false
        if next(info.mutations) == nil then
            pass = State.MutationAllow["(Normal)"] == true   -- item has no mutation
        else
            for name in pairs(info.mutations) do
                if State.MutationAllow[name] then pass = true break end
            end
        end
        if not pass then return false end
    end
    return true
end

-- Re-fire guard so one prompt isn't spammed every frame
local lastFired = setmetatable({}, { __mode = "k" })
local function tryGrab(prompt)
    if not State.AutoPickup or not prompt or not GRAB_PROMPTS[prompt.Name] then return false end
    if State.inAuction then return false end
    if not prompt.Enabled then return false end
    local model = carryableModelOf(prompt)
    if not isMine(model) then return false end  -- only your own items
    if prompt.Name == "PickupPrompt" then
        if not passesFilters(model) then return false end
        if isVehicleFar() then
            spawnVehicleSafe()
        end
    end
    
    local now = os.clock()
    if lastFired[prompt] and (now - lastFired[prompt]) < 0.4 then return false end
    lastFired[prompt] = now
    pcall(function() fireproximityprompt(prompt) end)
    State.itemsPicked = (State.itemsPicked or 0) + 1
    State.status = "🤲 Collected item (" .. State.itemsPicked .. ")"
    return true
end

local function scanNearbyPrompts()
    local carry = WS:FindFirstChild("_Carryables")
    if not carry or not rootPart then return end
    local origin = rootPart.Position
    for _, item in ipairs(carry:GetChildren()) do
        if not State.AutoPickup then break end
        if isMine(item) then  -- skip other players' items
            local base = item:FindFirstChild("Base") or item:FindFirstChildWhichIsA("BasePart")
            -- find a grab-able prompt on this item (much faster direct lookup)
            local prompt = base and (base:FindFirstChild("PickupPrompt") or base:FindFirstChild("OpenBoxPrompt"))
            if not prompt then
                prompt = item:FindFirstChild("PickupPrompt") or item:FindFirstChild("OpenBoxPrompt")
            end
            if base and prompt then
                local d = (base.Position - origin).Magnitude
                -- only fire if genuinely in the game's pickup range (server validates too)
                if d <= prompt.MaxActivationDistance then
                    tryGrab(prompt)
                end
            end
        end
    end
end

local pickupThread, promptShownConn
local function startAutoPickup()
    if pickupThread then pcall(task.cancel, pickupThread) end
    if promptShownConn then promptShownConn:Disconnect() end

    -- Instant-collect the moment a pickup prompt appears (you've walked into range)
    promptShownConn = PPS.PromptShown:Connect(function(prompt)
        tryGrab(prompt)
    end)

    -- Backup sweep for prompts already in range / that missed PromptShown
    pickupThread = task.spawn(function()
        while State.AutoPickup do
            scanNearbyPrompts()
            if (State.itemsPicked or 0) == 0 then
                State.status = "🤲 Auto pickup ON — walk near items"
            end
            task.wait(State.PickupScanDelay)
        end
    end)
    track(promptShownConn); trackThread(pickupThread)
end

-- ─── AUTO SHELF (inventory → shelf when there's a free slot) ───────────
-- Server-authoritative, so it works far from base. We try to place each inventory
-- item on a shelf slot and confirm by watching InventoryCount drop. If it doesn't
-- drop, the item didn't fit (too big for the plot / shelf full / not sellable), so
-- we leave it in the inventory and move on.
local InvEvents    = Events:WaitForChild("Inventory")
R.GetPlayerInv = InvEvents:WaitForChild("GetPlayerInventory")
R.ToggleFavoriteItem = InvEvents:WaitForChild("ToggleFavoriteItem")
R.PlaceStock   = PlotFolder:WaitForChild("PlaceStockItem")

-- Sell EVERYTHING in the inventory — Tools AND Vehicles are shelvable (vehicles go on
-- Large Floor Podiums). Nothing is skipped by category; keep what you want by
-- favoriting it (favorites are never shelved). Functional gear lives in the hotbar,
-- not the sellable inventory, so it's safe.
local SKIP_SHELF_CAT = {}

local cachedShelfSlots = nil
local lastSlotRefresh = 0

local function shelfSlots()
    if cachedShelfSlots and os.clock() - lastSlotRefresh < 10 then
        return cachedShelfSlots
    end
    
    local plot = State.myPlot or findMyPlot()
    State.myPlot = plot
    local out = {}
    if not plot then return out end
    for _, d in ipairs(plot:GetDescendants()) do
        if d:GetAttribute("IsShelf") then
            for _, a in ipairs(d:GetDescendants()) do
                if a:IsA("Attachment") and string.find(a.Name, "SnapPoint") then
                    out[#out + 1] = { shelf = d, att = a }
                end
            end
        end
    end
    cachedShelfSlots = out
    lastSlotRefresh = os.clock()
    return out
end

local function shelfPrice(id, entry)
    local data  = Items and Items[id]
    local price = 0
    if MutatorMod then
        pcall(function()
            price = MutatorMod:CalculatePriceForEntry((data and data.BasePrice) or 0,
                { ItemId = tonumber(id), Mutators = entry.Mutators or {}, Condition = entry.Condition }) or 0
        end)
    end
    return math.floor(price)
end

-- Read shelf occupancy directly: placed Stock models stream into PlotN.Stock when
-- you're at/near base. Each placed item sits on its nearest SnapPoint, so we map
-- items → slots and the leftover slots are EMPTY → we place only there (no
-- "occupied" spam). When the Stock folder is empty we can't read occupancy (far
-- away) and fall back to a capped blind round-robin.
-- Occupancy is NOT readable client-side: prompt.Enabled and streamed Stock both report
-- wrong values even when standing at the base. The only trustworthy signal is whether a
-- placement actually goes through (InventoryCount drops). So we DISCOVER occupancy
-- empirically: try a slot; if it's rejected we remember it as occupied and don't poke it
-- again until a sale frees a slot (LifetimeNPCSales ticks up), which re-opens discovery.
local shelfBusy      = false
local shelfOccupied  = {}     -- slotKey -> true: known occupied (re-learned after each sale)
local shelfFullLatch = false  -- every slot known-occupied; idle until a sale frees one
local shelfSalesMark = nil    -- LifetimeNPCSales watermark
local shelfTooBig    = {}     -- (kept so shelfEligibleItems stays simple; unused now)
local SHELF_MAX_SPAM = 4      -- cap failed "occupied" probes per pass

local function slotKeyOf(slot)
    return tostring(slot.shelf:GetAttribute("GUID")) .. "|" .. slot.att.Name
end

local function shelfEligibleItems(inv)
    local list = {}
    for guid, entry in pairs(inv) do
        local id   = tostring(entry.ItemId)
        local data = Items and Items[id]
        local name = data and data.Name
        local cat  = data and data.Category
        local fav     = (entry.Favorited == true)
        local tooRich = State.ShelfFilterPrice and (shelfPrice(id, entry) >= State.ShelfMaxPrice)
        local isDiamondSafe = (name == "Diamond Safe")
        if not (cat and SKIP_SHELF_CAT[cat]) and not shelfTooBig[guid] and not fav and not tooRich and not isDiamondSafe then
            list[#list + 1] = { guid = guid, id = id, data = data, entry = entry }
        end
    end
    return list
end

local function placeOnSlot(slot, it)
    local before = player:GetAttribute("InventoryCount") or 0
    local cf = slot.att.WorldCFrame * CFrame.Angles(0, math.rad((it.data and it.data.ShelfRotationY) or 0), 0)
    pcall(function()
        R.PlaceStock:FireServer(it.guid, it.id, cf, shelfPrice(it.id, it.entry),
            slot.shelf:GetAttribute("GUID"), slot.att.Name, false)
    end)
    if State.ShelfPlaceDelay > 0 then task.wait(State.ShelfPlaceDelay) end
    local success = (player:GetAttribute("InventoryCount") or 0) < before
    if success then
        PlacedItems[it.guid] = shelfPrice(it.id, it.entry)
    end
    return success
end

-- a slot is "big" (fits vehicles / large furniture) based on its shelf's name
local function slotIsBig(slot)
    local n = slot.shelf.Name
    return (string.find(n, "Large") or string.find(n, "Double") or string.find(n, "Table")) ~= nil
end
local BIG_ITEM_WEIGHT = 40   -- items >= this (vehicles, big appliances) need a big slot

local function doShelfPass()
    if shelfBusy then return 0 end
    shelfBusy = true
    local placed = 0
    pcall(function()
        local slots = shelfSlots()
        if #slots == 0 then return end

        local ok, inv = pcall(function() return R.GetPlayerInv:InvokeServer() end)
        if not ok or type(inv) ~= "table" then return end
        local items = shelfEligibleItems(inv)
        if #items == 0 then State.status = "🛒 Nothing to add"; return end

        -- Build real-time lookup map of occupied slots
        local occupiedSlots = {}
        local plot = State.myPlot or findMyPlot()
        if plot then
            for _, desc in ipairs(plot:GetDescendants()) do
                local sguid = desc:GetAttribute("ShelfGUID")
                local snapName = desc:GetAttribute("SnapPointName")
                if sguid and snapName then
                    occupiedSlots[sguid .. "_" .. snapName] = true
                end
            end
        end

        local bigSlots, smallSlots = {}, {}
        for _, s in ipairs(slots) do
            local k = s.shelf:GetAttribute("GUID") .. "_" .. s.att.Name
            if not occupiedSlots[k] then
                if slotIsBig(s) then bigSlots[#bigSlots + 1] = s else smallSlots[#smallSlots + 1] = s end
            end
        end

        table.sort(items, function(a, b)
            local wa = (a.data and a.data.Weight) or 0
            local wb = (b.data and b.data.Weight) or 0
            if State.PrioritizeHeavy then return wa > wb else return wa < wb end
        end)

        local fails = 0
        for _, it in ipairs(items) do
            if not State.AutoShelf or fails >= SHELF_MAX_SPAM then break end
            local w = (it.data and it.data.Weight) or 0
            local isBig = (w >= BIG_ITEM_WEIGHT) or (it.data and it.data.Category == "Vehicle")
            local candidates = {}
            if isBig then
                for _, s in ipairs(bigSlots) do candidates[#candidates + 1] = s end
            else
                for _, s in ipairs(smallSlots) do candidates[#candidates + 1] = s end
                for _, s in ipairs(bigSlots)   do candidates[#candidates + 1] = s end
            end
            
            for _, slot in ipairs(candidates) do
                if fails >= SHELF_MAX_SPAM then break end
                local k = slot.shelf:GetAttribute("GUID") .. "_" .. slot.att.Name
                if not occupiedSlots[k] then
                    if placeOnSlot(slot, it) then
                        occupiedSlots[k] = true
                        placed = placed + 1
                        State.status = "🛒 Shelved " .. placed .. " item(s)"
                        break
                    else
                        occupiedSlots[k] = true
                        fails = fails + 1
                    end
                end
            end
        end

        local totalFree = #bigSlots + #smallSlots
        if totalFree == 0 then
            State.status = "🛒 Shelf full — waiting for a sale"
        elseif placed == 0 then
            State.status = "🛒 Auto-shelf IDLE"
        end
    end)
    shelfBusy = false
    return placed
end

local shelfThread, shelfSalesConn
local function startAutoShelf()
