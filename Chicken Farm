-- periodic egg multiplier (Values.EggMultiplier, ~0.5..1.5, changes ~30s).
-- Deposit value = held eggs * this multiplier, so deposit at the peak.
local Values = ReplicatedStorage:FindFirstChild("Values")
local function eggMult()
    local em = Values and Values:FindFirstChild("EggMultiplier")
    return em and em.Value or 1
end
local depositThreshold = 1.5  -- "Smart Deposit" fires only when mult >= this

-- ===== Feature logic =====
local function doCollectEggs()
    local folder = workspace:FindFirstChild("Eggs")
    if not folder then return end
    for _, egg in folder:GetChildren() do
        if not egg:GetAttribute("LuckyBlock") then  -- skip lucky blocks (handled separately)
            Paper.Network.FireServer("Collect Egg", egg.Name)
            pcall(function() egg:Destroy() end)      -- remove visual so eggs don't linger
        end
    end
end

-- Lucky blocks: rain into workspace.Eggs (attr "LuckyBlock"=type). Open cost =
-- GetLuckyBlockCost(TotalChickens, type) = floor(BaseCost * TotalChickens^0.8).
-- Smart rule: only collect a block we can already AFFORD to open (prefer the rarest
-- affordable one), then open it immediately. Blocks we can't afford are left on the
-- ground (they linger ~5 min) until our cash grows enough.
local function lbCost(t) return ChickensMod.GetLuckyBlockCost(S("TotalChickens") or 0, t) end
local function doLuckyBlocks()
    local equipped = S("EquippedLuckyBlock") or 0
    if equipped > 0 then
        -- already holding one: open if free/affordable, else hold (or discard)
        if S("IsCurrentLuckyBlockFree") or (S("Cash") or 0) >= lbCost(equipped) then
            if Paper.Network.InvokeServer("Open Lucky Block") then
                Paper.Network.FireServer("Claim Opened Chicken")
            end
        elseif F.discardCostly then
            Paper.Network.FireServer("Discard Lucky Block")
        end
        return
    end
    -- slot empty: pick the rarest dropped block we can afford, collect + open it
    local folder = workspace:FindFirstChild("Eggs")
    if not folder then return end
    local cash = S("Cash") or 0
    local bestModel, bestType
    for _, m in folder:GetChildren() do
        local t = m:GetAttribute("LuckyBlock")
        if t and cash >= lbCost(t) and (not bestType or t > bestType) then
            bestType, bestModel = t, m
        end
    end
    if bestModel then
        if Paper.Network.InvokeServer("Collect Lucky Block", bestModel.Name) then
            pcall(function() bestModel:Destroy() end)
            if Paper.Network.InvokeServer("Open Lucky Block") then
                Paper.Network.FireServer("Claim Opened Chicken")
            end
        end
    end
end

local function doDepositEggs()
    if (S("Eggs") or 0) <= 0 then return end
    -- Smart Deposit: hold eggs until the multiplier is at/above the threshold
    if F.smartDeposit and eggMult() < depositThreshold then return end
    Paper.Network.InvokeServer("Deposit Eggs")
end

local function doCollectCash()
    if (S("CashCollect") or 0) > 0 then Paper.Network.InvokeServer("Collect Cash") end
end

local function buyCost(amt)
    return ChickensMod.GetBuyChickenCost(S("TotalChickens") or 0, S("BuyTierLevel") or 1, amt)
end
local function doBuyChickens()
    local cash = S("Cash") or 0
    for _, amt in ipairs({ 100, 25, 5, 1 }) do
        if buyAmounts[amt] and cash >= buyCost(amt) then
            Paper.Network.InvokeServer("Buy Chickens", amt)
            return
        end
    end
end

local function doMergeChickens()
    local c = S("Chickens")
    if type(c) ~= "table" then return end
    for tier, count in c do
        if count >= 3 and tier < MAX_TIER then
            Paper.Network.InvokeServer("Merge Chickens")
            return
        end
    end
end

local function doUpgradeTier()
    local tier = S("BuyTierLevel") or 1
    local cost = ChickensMod.GetUpgTierCost(tier)
    if not cost then return end  -- already max tier
    local req = ChickensMod.GetUpgTierReq(tier)
    if (S("TotalChickens") or 0) >= req and (S("Cash") or 0) >= cost then
        Paper.Network.InvokeServer("Upgrade Buy Tier Level")
    end
end

local function doUpgradeProc()
    local lvl = S("ProcessingLevel") or 1
    local cost = ChickensMod.GetProcessCost(lvl)
    if cost and (S("Cash") or 0) >= cost then
        Paper.Network.InvokeServer("Upgrade Process Level")
    end
end

