                ob.MouseButton1Click:Connect(function()
                    if o.value ~= nil or opts.allowNil then opts.onPick(o.value) end
                    close()
                end)
            end
        end
        btn.MouseButton1Click:Connect(function()
            local was = ddl.Visible
            closeAllDD()
            if not was then populate(); ddl.Visible = true; chev.Text = "^" end
        end)
