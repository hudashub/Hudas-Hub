            for i, o in ipairs(opts.options()) do
                local ob = Instance.new("TextButton")
                ob.Size = UDim2.new(1, 0, 0, 28); ob.BackgroundColor3 = COL.fieldHi
                ob.BackgroundTransparency = 1; ob.AutoButtonColor = false
