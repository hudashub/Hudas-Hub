local function findHighestValueLockableItem()
    local ok, res = pcall(function() return R.GetLockableItems:InvokeServer() end)
    if not ok or not res or type(res.items) ~= "table" then return nil end
    
    -- First pass: look for Diamond Safe items (prioritised)
    local diamondItem = nil
    local diamondPrice = -1
    -- Second pass fallback: highest value non-diamond item
    local highestItem = nil
    local highestPrice = -1
    
    for _, item in ipairs(res.items) do
        if item.data then
            local price = getLockableItemPrice(item)
            local id = tostring(item.data.ItemId or "")
            local itemName = Items and Items[id] and Items[id].Name or ""
            
            if string.find(itemName:lower(), "diamond") and (string.find(itemName:lower(), "safe") or string.find(itemName:lower(), "vault")) then
                if price > diamondPrice then
                    diamondPrice = price
                    diamondItem = item
                end
            else
                if price > highestPrice then
                    highestPrice = price
                    highestItem = item
                end
            end
        end
    end
    
    -- Prioritise Diamond Safe items over everything else
    if diamondItem then
        return diamondItem, diamondPrice
    end
    return highestItem, highestPrice
end

