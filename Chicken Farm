local function makeToggle(label, flagKey, parent, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 32); btn.BackgroundColor3 = COL.off; btn.AutoButtonColor = false
    btn.Text = ""; btn.LayoutOrder = order or 0; btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local bs = Instance.new("UIStroke", btn); bs.Color = COL.red; bs.Transparency = 0.6; bs.Thickness = 1
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -46, 1, 0); lbl.Position = UDim2.fromOffset(10, 0); lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamMedium; lbl.Text = label; lbl.TextColor3 = COL.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.TextSize = 12; lbl.TextTruncate = Enum.TextTruncate.AtEnd; lbl.Parent = btn
    local pill = Instance.new("Frame")
    pill.Size = UDim2.fromOffset(34, 18); pill.Position = UDim2.new(1, -40, 0.5, -9)
    pill.BackgroundColor3 = Color3.fromRGB(35,35,40); pill.Parent = btn
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)
    local knob = Instance.new("Frame")
    knob.Size = UDim2.fromOffset(14, 14); knob.Position = UDim2.fromOffset(2, 2)
    knob.BackgroundColor3 = Color3.fromRGB(120,120,130); knob.Parent = pill
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local function render()
        local on = F[flagKey]
        local okTween = pcall(function()
            knob:TweenPosition(UDim2.fromOffset(on and 18 or 2, 2), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
        end)
        if not okTween then knob.Position = UDim2.fromOffset(on and 18 or 2, 2) end
        pill.BackgroundColor3 = on and COL.on or Color3.fromRGB(35,35,40)
        knob.BackgroundColor3 = on and Color3.fromRGB(255,255,255) or Color3.fromRGB(120,120,130)
        btn.BackgroundColor3 = on and COL.redDim or COL.off
        bs.Transparency = on and 0.1 or 0.6
    end
    btn.MouseButton1Click:Connect(function() F[flagKey] = not F[flagKey]; render() end)
    controls[flagKey] = { get = function() return F[flagKey] end,
                          set = function(v) F[flagKey] = v and true or false; render() end }
    render(); return btn
end

local function makeChip(parent, text, stateTbl, stateKey, ctrlKey, order, widthUDim)
