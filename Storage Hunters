local function spawnVehicleSafe(garageModel)
    if not State.AutoSpawnVehicle then return end
    if State.inAuction then return end
    local bestGuid = getBestOwnedVehicleGuid()
    if not bestGuid or not rootPart then return end
    
    State.SpawningVehicle = true
    State.status = "🏪 Spawning best owned vehicle..."
    local hum = character and character:FindFirstChildOfClass("Humanoid")
    if hum and (hum.SeatPart or hum.Sit) then
        pcall(function() hum.Sit = false; hum.Jump = true end)
        task.wait(0.1)
    end
    
    local originalCF = rootPart.CFrame
    local garage = garageModel or findClosestGarage()
    local pad = garage and garage:FindFirstChild("EntrySquare", true)
    local promptPart = pad and (pad:FindFirstChild("PromptPart") or pad:FindFirstChildWhichIsA("BasePart") or pad)
    
    local spawnCFrame
    if promptPart and promptPart:IsA("BasePart") then
        local centerPart = garage:FindFirstChild("Floorspace") or garage:FindFirstChild("Base")
        local centerPos = centerPart and centerPart.Position or garage:GetPivot().Position
        local padPos = promptPart.Position
        local dir = (padPos - centerPos)
        dir = Vector3.new(dir.X, 0, dir.Z).Unit
        
        -- Spawn 25 studs forward from the bidding pad (into the road/driveway behind the bidders)
        local spawnPos = padPos + dir * 25 + Vector3.new(0, 1.5, 0)
        -- Perpendicular vector for sideways rotation (East/West relative to container)
        local sideDir = Vector3.new(-dir.Z, 0, dir.X).Unit
        spawnCFrame = CFrame.new(spawnPos, spawnPos + sideDir)
    else
        spawnCFrame = originalCF * CFrame.new(0, 0, 10) -- 10 studs behind us
    end
    
    -- Teleport 12 studs directly above the spawn spot to bypass collisions/doors
    rootPart.CFrame = spawnCFrame * CFrame.new(0, 12, 0)
    task.wait(0.25)
    
    pcall(function() R.RequestSpawn:FireServer(bestGuid) end)
    task.wait(0.8)
    
    if hum then
        local ejectStart = os.clock()
        while (hum.SeatPart or hum.Sit) and (os.clock() - ejectStart) < 2.5 do
            hum.Sit = false
            hum.Jump = true
            local seat = hum.SeatPart
            if seat then
                local weld = seat:FindFirstChild("SeatWeld")
                if weld then pcall(function() weld:Destroy() end) end
            end
            task.wait(0.05)
        end
    end
    
    rootPart.CFrame = originalCF
    task.wait(0.2)
    State.SpawningVehicle = false
end

local function ensureVehicleNearby(garageModel)
