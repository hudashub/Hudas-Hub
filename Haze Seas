local function attachHudToMob(mob)
    if not mob then return end
    local hrp = mob:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local hudTemplate = game.ReplicatedStorage:FindFirstChild("MobHUDTemplate")
    if not hudTemplate then return end
    local hud = hudTemplate:Clone()
    hud.Adornee = hrp
    hud.Parent = workspace
    -- Store reference for later cleanup
    mob:SetAttribute("HUDInstance", hud)
end


local function getHighestQuest()
    local pd = player:FindFirstChild("PlayerData")
    local exp = pd and pd:FindFirstChild("Experience")
    local level = exp and exp:FindFirstChild("Level")
    local lvl = level and level.Value or 1

    local highest = nil
    local highestReq = -1

    local logic = WS:FindFirstChild("Logic")
    local qPositions = logic and logic:FindFirstChild("QuestGiverPositions")
    if qPositions then
        for _, npcFolder in ipairs(qPositions:GetChildren()) do
            for _, qVal in ipairs(npcFolder:GetChildren()) do
                if qVal:IsA("IntValue") and qVal.Value <= lvl then
                    if qVal.Value > highestReq then
                        highestReq = qVal.Value
                        highest = {
                            NPC = npcFolder.Name,
                            Quest = qVal.Name,
                            Req = qVal.Value
                        }
                    end
                end
            end
        end
    end
    return highest
end

local function getActiveQuest()
    local gui = player:FindFirstChild("PlayerGui") and player.PlayerGui:FindFirstChild("QuestGui")
    local mf = gui and gui:FindFirstChild("MainFrame")
    if mf and mf.Visible then
        local qNameLabel = mf:FindFirstChild("QuestName")
        local qObjectiveLabel = mf:FindFirstChild("QuestObjective")
        local amtLabel = mf:FindFirstChild("AmountMobs")
        
        if qNameLabel and qNameLabel.Text ~= "" and qNameLabel.Text ~= "Quest: None" then
            local prog, target = 0, 0
            if amtLabel then
                local p, t = amtLabel.Text:match("(%d+)/(%d+)")
                prog = tonumber(p) or 0
                target = tonumber(t) or 0
            end
            
            local mobName = ""
            if qObjectiveLabel then
                -- Extract the mob name from "Kill X Mobs"
                local nameStr = qObjectiveLabel.Text:match("Kill %d+ (.*)")
                if nameStr then
                    mobName = nameStr
                else
                    mobName = qObjectiveLabel.Text
                end
            end
            
            return {
                QuestName = qNameLabel.Text:gsub("Quest: ", ""),
                NPCName = mobName,
                Progress = prog,
                Target = target
            }
        end
    end
    return nil
end

local function tweenTo(cframe, speed)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not root then return end
    
    -- Anchor and PlatformStand to prevent physics/collision camera jitter
    root.Anchored = true
    if hum then hum.PlatformStand = true end
    
    speed = speed or 150
    local dist = (root.Position - cframe.Position).Magnitude
    local time = dist / speed
    local ti = TweenInfo.new(time, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(root, ti, {CFrame = cframe})
    tween:Play()
    return tween
end


