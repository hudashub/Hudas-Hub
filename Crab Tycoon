local function get(k) local ok, v = pcall(function() return Mirror.get(k) end) return ok and v or nil end

local function crabCounts()
    local tiers = get("crabTiers") or {}
    local byTier, n = {}, #tiers
    for _, t in tiers do byTier[t] = (byTier[t] or 0) + 1 end
    return n, byTier
end

local function buyCost(amount)
    local power   = get("crabPower") or 0
    local buyTier = get("buyTier") or 1
    local mult    = 3 ^ (buyTier - 1)
    local base    = (power <= 0) and 5 or math.floor(5 + 2.1 * power ^ 0.875)
    return base * amount * mult
end

