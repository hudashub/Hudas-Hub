    chip.MouseButton1Click:Connect(function() stateTbl[stateKey] = not stateTbl[stateKey]; render() end)
    controls[ctrlKey] = { get = function() return stateTbl[stateKey] end,
                          set = function(v) stateTbl[stateKey] = v and true or false; render() end }
    render()
end

