local function slider(lbl, minV, maxV, defV, fn, key)
    local row = Instance.new("Frame", currentCol)
    row.Size = UDim2.new(1, 0, 0, 54)
    row.BackgroundColor3 = Color3.fromRGB(12, 12, 14)
    row.BorderSizePixel = 0; row.LayoutOrder = nextOrder; nextOrder = nextOrder + 1
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    local rst = Instance.new("UIStroke", row); rst.Color = Color3.fromRGB(235, 70, 50); rst.Transparency = 0.85; rst.Thickness = 1
    
    mkLabel(row, lbl, UDim2.new(0.58, 0, 0, 20), UDim2.new(0, 12, 0, 4), 12, nil, Color3.fromRGB(180, 180, 180), 1, Enum.TextXAlignment.Left)
    local vl = mkLabel(row, tostring(defV), UDim2.new(0.38, 0, 0, 20), UDim2.new(0.6, 0, 0, 4), 12, Enum.Font.GothamBold, Color3.fromRGB(235, 70, 50), 1, Enum.TextXAlignment.Right)
    
    local trk = Instance.new("Frame", row)
    trk.Size = UDim2.new(1, -24, 0, 6)
    trk.Position = UDim2.new(0, 12, 0, 36)
    trk.BackgroundColor3 = Color3.fromRGB(30, 30, 36)
    trk.BorderSizePixel = 0
    Instance.new("UICorner", trk).CornerRadius = UDim.new(1, 0)
    
    local pct = (defV - minV) / (maxV - minV)
    local fl = Instance.new("Frame", trk)
    fl.Size = UDim2.new(pct, 0, 1, 0)
    fl.BackgroundColor3 = Color3.fromRGB(235, 70, 50)
    fl.BorderSizePixel = 0
    Instance.new("UICorner", fl).CornerRadius = UDim.new(1, 0)
    
    local th = Instance.new("TextButton", trk)
    th.Size = UDim2.fromOffset(14, 14)
    th.Position = UDim2.new(pct, -7, 0.5, -7)
    th.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
    th.Text = ""; th.BorderSizePixel = 0; th.ZIndex = 2
    Instance.new("UICorner", th).CornerRadius = UDim.new(1, 0)
    
    local function setSlider(v)
        v = math.clamp(math.floor(tonumber(v) or defV), minV, maxV)
        local r = (v - minV) / (maxV - minV)
        fl.Size = UDim2.new(r, 0, 1, 0)
        th.Position = UDim2.new(r, -7, 0.5, -7)
        vl.Text = tostring(v); fn(v)
    end
    
    local drag = false
    th.MouseButton1Down:Connect(function() drag = true end)
    track(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end))
    track(RunService.RenderStepped:Connect(function()
        if not drag then return end
        local r = math.clamp((UserInputService:GetMouseLocation().X - trk.AbsolutePosition.X) / trk.AbsoluteSize.X, 0, 1)
        setSlider(minV + r * (maxV - minV))
    end))
    
    controls[key or lbl] = {
        get = function() return tonumber(vl.Text) or defV end,
        set = setSlider,
    }
end

