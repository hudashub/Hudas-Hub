-- ============================================================
--  AUTO-FARM LOOP  (walk -> engage -> wait battle -> repeat)
-- ============================================================
-- Wild Evomon roam, so we can't walk to a captured position — chase the LIVE
-- model, re-targeting as it moves, until close (or a time budget runs out). The
-- server tolerates entry from ~20+ studs, so we don't need to be on top of it.
local function walkToCreature(uid, stopDist, maxTime)
    navToken = navToken + 1
    local myTok = navToken
    stopDist = stopDist or 16; maxTime = maxTime or 12
    navStatus = "walking"
    local t0 = os.clock()
    while navToken == myTok and alive() do
        local cc = creatureCache()
        local model = cc and cc:FindFirstChild(uid)
        if not model then navStatus = "target gone"; return false end
        local r, h = myRoot()
        if not (r and h) then return false end
        local ok, piv = pcall(function() return model:GetPivot() end)
        if not ok then return false end
        local d = (piv.Position - r.Position).Magnitude
        if d <= stopDist then navStatus = "arrived"; return true end
        if os.clock() - t0 > maxTime then navStatus = "timeout"; return d <= stopDist + 24 end
        h:MoveTo(piv.Position)
        task.wait(0.3)
    end
    return false
end

task.spawn(function()
    while alive() do
        if F.autoFarm and not inBattle then
            local c = nearestWild()
            if c then
                walkToCreature(c.uid, 16, 12)   -- chase the roaming wild
                -- engage if still farming, not in battle, and the creature still
                -- exists. NO canEnter gate — it returns BATTLE_IN_PROGRESS at range
                -- and would block every engage; the raw FireServer is tolerant and
                -- the server is the real authority.
                local cc0 = creatureCache()
                local model = cc0 and cc0:FindFirstChild(c.uid)
                if F.autoFarm and not inBattle and model then
