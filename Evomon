        local renders = {}
        local function renderAll() for _, r in ipairs(renders) do r() end end
        for i, it in ipairs(items) do
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1 / #items, -4, 1, 0); b.AutoButtonColor = false
            b.Font = Enum.Font.GothamBold; b.Text = it.label; b.TextSize = 11
            b.LayoutOrder = i; b.Parent = seg
            corner(b, 6)
            local function render()
                local on = stateTbl[it.key]
                b.BackgroundColor3 = on and COL.red or COL.field
                b.BackgroundTransparency = on and 0 or 1
                b.TextColor3 = on and COL.white or COL.sub
            end
            b.MouseEnter:Connect(function() if not stateTbl[it.key] then tween(b, 0.12, { TextColor3 = COL.text }) end end)
            b.MouseLeave:Connect(function() if not stateTbl[it.key] then tween(b, 0.12, { TextColor3 = COL.sub }) end end)
            b.MouseButton1Click:Connect(function()
                for k in pairs(stateTbl) do stateTbl[k] = false end
                stateTbl[it.key] = true
                renderAll()
            end)
            controls[it.ctrl] = { get = function() return stateTbl[it.key] end,
                                  set = function(v) stateTbl[it.key] = v and true or false; renderAll() end }
            renders[i] = render
        end
        renderAll()
        return seg
    end

