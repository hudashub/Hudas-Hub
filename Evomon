-- CRIT PRIORITY: at battle start, if the active pet has a crit-setup skill
-- (Store Power / Critical Focus / Steel Smash …) with PP, cast it once. Fully
-- guarded — a wrong/early operate is simply rejected by the server, no harm.
local function doCritOpener()
    pcall(function()
        local mb = getCtrl("MainBattleWindowController")
        if not (mb and typeof(mb.getBattleDataCache) == "function" and BattleDataGet) then return end
        local cache = mb.getBattleDataCache()
        if type(cache) ~= "table" then return end
        local act = BattleDataGet.getActivePetsData(cache)
        local myPet = act and act.selfPets and act.selfPets[1]
        if type(myPet) ~= "table" or type(myPet.skills) ~= "table" then return end
        local chosen
        for _, sk in ipairs(myPet.skills) do
            local sid = sk.id or sk.skillId
            local pp = sk.pp
            if sid and isCritSkill(sid) and (pp == nil or pp > 0) then
                local isSetup = (sk.skillCategory == 3) or (sk.aiType and tostring(sk.aiType):find("Buff"))
                if isSetup then chosen = sk; break end
                if not chosen then chosen = sk end
            end
        end
        if not chosen or not ReqOperateBattle then return end
        local myCamp = myPet.campId or 1
        ReqOperateBattle:InvokeServer({
            actionType   = 1,
            skillType    = chosen.type or chosen.skillType or 1,
            skillId      = chosen.id or chosen.skillId,
            sourceUid    = tostring(myPet.uid),
            sourcePos    = myPet.pos or myPet.groupPos or 1,
            targetPos    = 1,
            targetCampId = (myCamp == 1) and 2 or 1,
        })
    end)
end

-- SMART BATTLE: element-aware manual driver. Picks a super-effective damage move
-- (skill element restrains an enemy element) if one exists; otherwise the highest
-- power damage move. Crit-setup skill takes turn 1 when Crit Priority is also on.
local skillElemCache = {}
local function skillElement(id)
    if skillElemCache[id] ~= nil then return skillElemCache[id] or nil end
    local el
    pcall(function() local c = CM and CM.getConfig(CN.SKILL, id); if type(c) == "table" then el = c.element end end)
    skillElemCache[id] = el or false
    return el
end
local function isSuperEffective(myEl, enemyEls)
    if not myEl or type(enemyEls) ~= "table" then return false end
    local c = CM and CM.getConfig(CN.ELEMENT_COUNTER, myEl)
    if type(c) ~= "table" or type(c.restraint) ~= "table" then return false end
    local set = {}; for _, e in ipairs(c.restraint) do set[e] = true end
    for _, ee in ipairs(enemyEls) do if set[ee] then return true end end
    return false
end
local function pickSmartMove(firstTurn)
    local mb = getCtrl("MainBattleWindowController")
    if not (mb and typeof(mb.getBattleDataCache) == "function" and BattleDataGet) then return nil end
    local cache = mb.getBattleDataCache()
    if type(cache) ~= "table" then return nil end
    local act = BattleDataGet.getActivePetsData(cache)
    local my = act and act.selfPets and act.selfPets[1]
    local en = act and act.enemyPets and act.enemyPets[1]
    if type(my) ~= "table" or type(my.skills) ~= "table" then return nil end
    local enemyEls = (type(en) == "table" and type(en.elements) == "table") and en.elements or {}
    -- my camp + current energy. ULTIMATE skills (type 2, have a `cost`) need
    -- energy; firing one without enough energy is rejected and the turn falls
    -- back to a normal attack — the bug. So skills are only "usable" if a
    -- regular move has PP, or an ultimate's cost is covered by current energy.
    local myCamp = 1
    pcall(function() if BattleDataGet.getLocalPlayerCampId then myCamp = BattleDataGet.getLocalPlayerCampId(cache) or 1 end end)
    local energy = 0
    pcall(function()
        local camp = cache["camp" .. tostring(myCamp)]
        if type(camp) == "table" and type(camp.trainers) == "table" then
            for _, tr in pairs(camp.trainers) do
                if type(tr) == "table" and type(tr.energy) == "number" then energy = math.max(energy, tr.energy) end
            end
        end
    end)
    local function usable(sk)
        if sk.type == 2 or sk.cost then return energy >= (sk.cost or 0) end
        return (sk.pp == nil or sk.pp > 0)
    end
    -- turn 1: crit setup skill if Crit Priority on
    if firstTurn and F.critPriority then
        for _, sk in ipairs(my.skills) do
            local sid = sk.id or sk.skillId
            if sid and isCritSkill(sid) and usable(sk)
               and ((sk.skillCategory == 3) or (sk.aiType and tostring(sk.aiType):find("Buff"))) then
                return sk, my, myCamp
            end
        end
    end
    -- USABLE damage skills: strongest super-effective first, else strongest
    local best, bestPow, sup, supPow = nil, -1, nil, -1
    for _, sk in ipairs(my.skills) do
        local sid = sk.id or sk.skillId
        local isDmg = (sk.skillCategory == 1) or (sk.skillCategory == 2) or (sk.aiType == "Damage")
        if sid and isDmg and usable(sk) then
            local pw = sk.power or 0
            if isSuperEffective(skillElement(sid), enemyEls) and pw > supPow then sup, supPow = sk, pw end
            if pw > bestPow then best, bestPow = sk, pw end
        end
    end
    return (sup or best), my, myCamp
end
local function operateSkill(sk, my, myCamp)
    if not (sk and my and ReqOperateBattle) then return end
    local enemyCamp = (myCamp == 1) and 2 or 1
    pcall(function()
        ReqOperateBattle:InvokeServer({
            actionType   = 1,
            skillType    = sk.type or sk.skillType or 1,
            skillId      = sk.id or sk.skillId,
            sourceUid    = tostring(my.uid),
            sourcePos    = 1,
            targetPos    = 1,
            targetCampId = enemyCamp,
        })
    end)
end

do
    local function hook(remoteName, fn)
        local r = BattleRemote and BattleRemote:FindFirstChild(remoteName)
        if r then track(r.OnClientEvent:Connect(fn)) end
    end
    hook("ResEnterBattle", function()
        inBattle = true
        pendingEntry = false
        task.delay(1.4, function()
            if not (inBattle and alive()) then return end
            if F.smartBattle then return end   -- smart driver handles it instead
            if F.critPriority then doCritOpener() end
            if F.autoBattle then
                task.delay(0.6, function()
                    if F.autoBattle and inBattle and ReqAutoBattle then
                        pcall(function() ReqAutoBattle:InvokeServer(true) end)
                    end
                end)
            end
        end)
    end)
    hook("ResEnterBattleFail", function() inBattle = false; pendingEntry = false; clearBattleTransition() end)
    hook("ResSettleBattle",   function() inBattle = false; pendingEntry = false end)
end

-- smart-battle turn driver. Reads the live battle cache directly (NOT the
-- inBattle flag, which can go stale across a reload) and acts when status is
-- WAIT_OPERATION (2) on a new round. round-dedup avoids double-firing a turn;
-- getCanOperate() pulses, so it's only a soft confirm, not the trigger.
task.spawn(function()
    local actedAt = nil       -- os.clock of our last operate while in this WAIT_OPERATION phase
    local firstOfBattle = true
    while alive() do
        if F.smartBattle then
            local mb = getCtrl("MainBattleWindowController")
            local bc
            if mb and typeof(mb.getBattleDataCache) == "function" then pcall(function() bc = mb.getBattleDataCache() end) end
            if type(bc) == "table" and bc.sessionPhase == "active" and bc.status == 2 then
                local can = true
                if typeof(mb.getCanOperate) == "function" then pcall(function() can = mb.getCanOperate() end) end
                -- act when it's our turn; re-fire if we acted but the phase is still
                -- WAIT_OPERATION after ~1.6s (the move was rejected/premature — the
                -- round counter can tick before our input is actually accepted).
                if can and (actedAt == nil or (os.clock() - actedAt) > 1.6) then
                    local sk, my, myCamp = pickSmartMove(firstOfBattle)
                    if sk and my then operateSkill(sk, my, myCamp); actedAt = os.clock(); firstOfBattle = false end
                end
            else
                actedAt = nil     -- left the operate phase (settle/anim/catch) -> re-arm for next turn
                if type(bc) ~= "table" then firstOfBattle = true end   -- battle ended
            end
        else
            actedAt = nil; firstOfBattle = true
        end
        task.wait(0.3)
    end
end)

-- Use the RAW remote, not BattleService.enterPetBattle. enterPetBattle enqueues
-- a pre-enter camera fade that gets stuck on black if the server is slow to
-- confirm; the raw FireServer just starts the battle (verified: triggers
-- ResEnterBattle reliably, even from ~20 studs) with no fade to get stuck.
local function startWildBattle(uid)
    pendingEntry = true
    if ReqEnterPetBattle then
        pcall(function() ReqEnterPetBattle:FireServer(uid) end)
    elseif BattleService and typeof(BattleService.enterPetBattle) == "function" then
        pcall(function() BattleService.enterPetBattle(uid) end)
    end
end

-- ============================================================
--  FAST BATTLE  (client-side playback speed override)
--  All BattleChoreo nodes scale animation timing by
--  MainBattleWindowController.getBattlePlaybackSpeed(). The game gates 2X
--  behind a paid privilege, but the multiplier itself is purely client-side.
--  We wrap it: while F.fastBattle is on, return our chosen multiplier;
--  otherwise defer to the game's original (paid 2X / 1X). Installed once;
--  _G holds the TRUE original so re-exec never stacks wrappers.
-- ============================================================
pcall(function()
    local MBWC = require(ReplicatedStorage.Controller.MainBattleWindowController)
    if typeof(MBWC.getBattlePlaybackSpeed) == "function" then
        if not _G.__Evomon_origSpeed then _G.__Evomon_origSpeed = MBWC.getBattlePlaybackSpeed end
        MBWC.getBattlePlaybackSpeed = function(...)
            if F.fastBattle then return activeBattleSpeed() end
            return _G.__Evomon_origSpeed(...)
        end
    end
end)

-- ============================================================
--  NAVIGATION  (pathfind WALK — no teleport, plausible speed)
-- ============================================================
local navToken = 0
local navStatus = "idle"
local function stopNav()
    navToken = navToken + 1
    navStatus = "idle"
    -- cancel any residual MoveTo so the player regains control immediately
    local r, h = myRoot()
    if r and h then pcall(function() h:MoveTo(r.Position) end) end
end

-- walk to a world position; returns when arrived / failed / cancelled
local function walkTo(targetPos)
    navToken = navToken + 1
    local myTok = navToken
    local root, hum = myRoot()
    if not (root and hum) then navStatus = "no character"; return false end
    navStatus = "walking"
    local path = PathfindingService:CreatePath({
        AgentRadius = 3, AgentHeight = 5, AgentCanJump = true, WaypointSpacing = 6,
    })
    local okC = pcall(function() path:ComputeAsync(root.Position, targetPos) end)
    local waypoints = (okC and path.Status == Enum.PathStatus.Success) and path:GetWaypoints() or nil

    local function moveStep(pos)
        if navToken ~= myTok or not alive() then return false end
        local _, h = myRoot()
        if not h then return false end
        h:MoveTo(pos)
        local done = false
        local conn
        conn = h.MoveToFinished:Connect(function() done = true end)
        local t = 0
        while not done and t < 4 and navToken == myTok and alive() do task.wait(0.1); t = t + 0.1 end
        if conn then conn:Disconnect() end
        return navToken == myTok
    end

    if waypoints then
        for _, wp in ipairs(waypoints) do
            if navToken ~= myTok or not alive() then navStatus = "cancelled"; return false end
            if wp.Action == Enum.PathWaypointAction.Jump then local _, h = myRoot(); if h then h.Jump = true end end
            if not moveStep(wp.Position) then navStatus = "cancelled"; return false end
        end
    else
        -- no path -> direct (best-effort); step toward the target in chunks
        for _ = 1, 30 do
            if navToken ~= myTok or not alive() then navStatus = "cancelled"; return false end
            local r = myRoot()
            if not r then break end
            if (r.Position - targetPos).Magnitude < 8 then break end
            if not moveStep(targetPos) then navStatus = "cancelled"; return false end
        end
    end
    if navToken == myTok then navStatus = "arrived" end
    return navToken == myTok
end

