local function getContainerValuation(garageModel)
    if not garageModel then return 0, 0 end
    local totalVal = 0
    local itemCount = 0
    
    local function scanFolder(folder)
        if not folder then return end
        for _, item in ipairs(folder:GetChildren()) do
            if item:IsA("Model") and item.Name ~= "Button" and item.Name ~= "Door" and item.Name ~= "Auctioneer" and item.Name ~= "Sal" and item.Name ~= "Dwayne" and item.Name ~= "Floyd" and item.Name ~= "Connie" and item.Name ~= "Rosa" then
                local info = resolveItemInfo(item)
                if info and info.price and info.price > 0 then
                    totalVal = totalVal + info.price
                    itemCount = itemCount + 1
                else
                    local itemId = item:GetAttribute("ItemId")
                    local data = nil
                    if itemId then
                        data = Items[tostring(itemId)]
                    else
                        for id, entry in pairs(Items) do
                            if entry.Name == item.Name then
                                data = entry
                                break
                            end
                        end
                    end
                    if data and data.BasePrice then
                        totalVal = totalVal + data.BasePrice
                        itemCount = itemCount + 1
                    else
                        local expectedPrice = ExpectedValues[item.Name]
                        if expectedPrice then
                            totalVal = totalVal + expectedPrice
                            itemCount = itemCount + 1
                        end
                    end
                end
            end
        end
    end
    
    scanFolder(garageModel:FindFirstChild("Parts"))
    scanFolder(garageModel:FindFirstChild("Floorspace"))
    
    return totalVal, itemCount
end

